---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import Button from "../components/Button.astro";
import { href } from "../lib/url";
import { artById } from "../lib/shop-items";
---

<Base
  title="Your bag"
  description="Review your TinyPaws gift-shop bag — a demo cart with no payments."
>
  <PageHero title="Your bag" lead="Demo cart — quantities work, totals add up, and no money moves anywhere." />

  <section class="section">
    <div class="container cart-wrap" data-art={JSON.stringify(artById)}>
      <div class="cart-empty" hidden>
        <p>Your bag is empty — the kittens suggest a mug.</p>
        <Button href={href("/shop/")}>Back to the shop</Button>
      </div>

      <div class="cart-full" hidden>
        <div class="cart-grid">
          <div>
            <ul class="cart-list"></ul>
            <a class="cart-back" href={href("/shop/")}>‹ Keep shopping</a>
          </div>
          <aside class="cart-summary" aria-label="Order summary">
            <h2>Summary</h2>
            <dl class="sum-rows">
              <div><dt>Subtotal</dt><dd class="sum-subtotal"></dd></div>
              <div><dt>Shipping</dt><dd>Free — local pickup</dd></div>
              <div class="sum-total-row"><dt>Total</dt><dd class="sum-total"></dd></div>
            </dl>
            <Button href={href("/checkout/")}>Proceed to checkout</Button>
            <p class="cart-note">Demo — checkout collects nothing and charges nothing.</p>
          </aside>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  import { loadBag, saveBag, bagTotal } from "../lib/bag";

  const wrap = document.querySelector<HTMLElement>(".cart-wrap")!;
  const art: Record<string, string> = JSON.parse(wrap.dataset.art!);
  const empty = wrap.querySelector<HTMLElement>(".cart-empty")!;
  const full = wrap.querySelector<HTMLElement>(".cart-full")!;
  const list = wrap.querySelector<HTMLElement>(".cart-list")!;
  const subEl = wrap.querySelector<HTMLElement>(".sum-subtotal")!;
  const totalEl = wrap.querySelector<HTMLElement>(".sum-total")!;

  const render = () => {
    const bag = loadBag();
    empty.hidden = bag.length > 0;
    full.hidden = bag.length === 0;
    if (!bag.length) return;
    list.innerHTML = "";
    for (const item of bag) {
      const li = document.createElement("li");
      li.className = "cart-row";

      const thumb = document.createElement("span");
      thumb.className = "row-thumb";
      thumb.setAttribute("aria-hidden", "true");
      thumb.innerHTML = art[item.id] ?? "";

      const info = document.createElement("span");
      info.className = "row-info";
      const name = document.createElement("span");
      name.className = "row-name";
      name.textContent = item.name;
      const each = document.createElement("span");
      each.className = "row-each";
      each.textContent = `$${item.price} each`;
      info.append(name, each);

      const qty = document.createElement("span");
      qty.className = "row-qty";
      const minus = document.createElement("button");
      minus.type = "button";
      minus.textContent = "−";
      minus.setAttribute("aria-label", `One fewer ${item.name}`);
      const n = document.createElement("span");
      n.className = "row-n";
      n.textContent = String(item.qty);
      const plus = document.createElement("button");
      plus.type = "button";
      plus.textContent = "+";
      plus.setAttribute("aria-label", `One more ${item.name}`);
      qty.append(minus, n, plus);

      const line = document.createElement("span");
      line.className = "row-line";
      line.textContent = `$${item.qty * item.price}`;

      const remove = document.createElement("button");
      remove.type = "button";
      remove.className = "row-remove";
      remove.textContent = "×";
      remove.setAttribute("aria-label", `Remove ${item.name}`);

      minus.addEventListener("click", () => { item.qty -= 1; saveBag(bag); render(); });
      plus.addEventListener("click", () => { item.qty += 1; saveBag(bag); render(); });
      remove.addEventListener("click", () => { item.qty = 0; saveBag(bag); render(); });

      li.append(thumb, info, qty, line, remove);
      list.append(li);
    }
    const total = bagTotal(bag);
    subEl.textContent = `$${total}`;
    totalEl.textContent = `$${total}`;
  };
  render();
</script>

<style>
  .cart-wrap { max-width: 1040px; }
  .cart-empty {
    display: grid;
    justify-items: start;
    gap: var(--space-3);
  }
  .cart-grid {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--space-4);
    align-items: start;
  }
  .cart-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 12px;
  }
  .cart-row {
    display: grid;
    grid-template-columns: 88px 1fr auto auto auto;
    align-items: center;
    gap: var(--space-2);
    background: var(--paw-white);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    padding: 14px 18px;
  }
  .row-thumb {
    width: 88px;
    height: 70px;
    background: var(--paw-cream);
    border-radius: var(--radius-input);
    overflow: hidden;
  }
  .row-thumb :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }
  .row-info { display: grid; gap: 2px; }
  .row-name { font: 500 1.05rem/1.3 var(--font-display); }
  .row-each {
    font-size: var(--size-small);
    color: rgba(48, 24, 0, 0.6);
  }
  .row-qty {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--paw-cream);
    border-radius: var(--radius-pill);
    padding: 4px;
  }
  .row-qty button {
    all: unset;
    cursor: pointer;
    width: 30px;
    height: 30px;
    display: inline-grid;
    place-items: center;
    border-radius: 50%;
    background: var(--paw-white);
    font-weight: 600;
  }
  .row-qty button:hover { background: var(--paw-cream-deep); }
  .row-qty button:focus-visible { outline: 3px solid var(--paw-orange); }
  .row-n { min-width: 16px; text-align: center; font-weight: 600; }
  .row-line {
    font: 600 1.1rem/1 var(--font-display);
    color: var(--paw-orange-ink);
    min-width: 52px;
    text-align: right;
  }
  .row-remove {
    all: unset;
    cursor: pointer;
    width: 32px;
    height: 32px;
    display: inline-grid;
    place-items: center;
    border-radius: 50%;
    color: rgba(48, 24, 0, 0.55);
    font-size: 1.3rem;
  }
  .row-remove:hover {
    background: var(--paw-cream);
    color: var(--paw-brown);
  }
  .row-remove:focus-visible { outline: 3px solid var(--paw-orange); }
  .cart-back {
    display: inline-block;
    margin-top: var(--space-3);
    font-weight: 500;
    text-decoration: none;
  }
  .cart-back:hover { text-decoration: underline; text-underline-offset: 3px; }
  .cart-summary {
    background: var(--paw-cream);
    border-radius: var(--radius-card);
    padding: var(--space-3);
    position: sticky;
    top: 92px;
    display: grid;
    gap: var(--space-2);
    justify-items: start;
  }
  .sum-rows {
    margin: 0;
    width: 100%;
    display: grid;
    gap: 10px;
  }
  .sum-rows div {
    display: flex;
    justify-content: space-between;
    gap: 12px;
  }
  .sum-rows dt { color: rgba(48, 24, 0, 0.7); }
  .sum-rows dd { margin: 0; font-weight: 600; }
  .sum-total-row {
    padding-top: 10px;
    border-top: 1px solid rgba(48, 24, 0, 0.15);
  }
  .sum-total-row dt,
  .sum-total-row dd {
    font: 600 1.2rem/1 var(--font-display);
    color: var(--paw-brown);
  }
  .cart-note {
    font-size: var(--size-small);
    color: rgba(48, 24, 0, 0.65);
  }
  @media (max-width: 900px) {
    .cart-grid { grid-template-columns: 1fr; }
    .cart-summary { position: static; }
  }
  @media (max-width: 640px) {
    .cart-row {
      grid-template-columns: 72px 1fr auto;
      row-gap: 10px;
    }
    .row-thumb { width: 72px; height: 58px; }
    .row-line { grid-column: 2; text-align: left; }
    .row-qty { grid-column: 2 / 4; justify-self: start; }
  }
</style>
