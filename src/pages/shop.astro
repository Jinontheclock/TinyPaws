---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";

/* the hi-fi Gift Shop, demo-honest: illustrated products (same stand-in
   language as the cat portraits), a working bag, no checkout */
const items = [
  { id: "tee", name: "Classic logo tee", price: 25, blurb: "Soft cotton, tiny paw over the heart." },
  { id: "mug", name: "Morning mug", price: 18, blurb: "For the human the cat allows to share the sofa." },
  { id: "tote", name: "Everyday tote", price: 20, blurb: "Carries litter, groceries, and the occasional kitten toy." },
  { id: "stickers", name: "Sticker sheet", price: 8, blurb: "Twelve tiny paws for laptops and water bottles." },
  { id: "beanie", name: "Paw beanie", price: 22, blurb: "Cream knit, embroidered paw. Vancouver-winter approved." },
  { id: "print", name: "Calico art print", price: 15, blurb: "The brand palette, straight from calico fur. A4." },
];
---

<Base
  title="Gift shop"
  description="TinyPaws merch — tees, mugs, totes, and stickers. Every dollar of profit goes to veterinary care."
>
  <PageHero
    title="Gift shop"
    lead="Every dollar of profit goes straight to vet bills. The cats thank you — in their own way, eventually."
  />

  <section class="section">
    <div class="container">
      <p class="shop-note">
        Demo shop — the bag works, but there's no checkout and no payments.
        In the live site this connects to the rescue's store provider.
      </p>
      <h2 class="sr-only">Products</h2>
      <div class="shop-grid">
        {items.map((it) => (
          <article class="product" data-id={it.id} data-name={it.name} data-price={it.price}>
            <div class={`product-art product-art--${it.id}`} aria-hidden="true">
              <svg viewBox="0 0 200 160">
                {it.id === "tee" && (
                  <path d="M60 30 L85 20 Q100 32 115 20 L140 30 L155 55 L136 64 L136 135 L64 135 L64 64 L45 55 Z" fill="#F5ECD8" stroke="#301800" stroke-width="5" stroke-linejoin="round" />
                )}
                {it.id === "tee" && <circle cx="100" cy="80" r="14" fill="#DC6E00" />}
                {it.id === "mug" && (
                  <g>
                    <rect x="60" y="40" width="70" height="80" rx="12" fill="#DC6E00" stroke="#301800" stroke-width="5" />
                    <path d="M130 55 h14 a16 16 0 0 1 0 40 h-14" fill="none" stroke="#301800" stroke-width="5" />
                    <circle cx="95" cy="80" r="13" fill="#F5ECD8" />
                  </g>
                )}
                {it.id === "tote" && (
                  <g>
                    <path d="M55 55 L145 55 L138 135 L62 135 Z" fill="#F5ECD8" stroke="#301800" stroke-width="5" stroke-linejoin="round" />
                    <path d="M75 55 Q75 25 100 25 Q125 25 125 55" fill="none" stroke="#301800" stroke-width="5" />
                    <circle cx="100" cy="95" r="14" fill="#DC6E00" />
                  </g>
                )}
                {it.id === "stickers" && (
                  <g>
                    <rect x="45" y="35" width="110" height="90" rx="10" fill="#FFFFFF" stroke="#301800" stroke-width="5" />
                    <circle cx="75" cy="65" r="10" fill="#DC6E00" />
                    <circle cx="105" cy="65" r="10" fill="#301800" />
                    <circle cx="135" cy="65" r="10" fill="#DC6E00" />
                    <circle cx="90" cy="95" r="10" fill="#301800" />
                    <circle cx="120" cy="95" r="10" fill="#DC6E00" />
                  </g>
                )}
                {it.id === "beanie" && (
                  <g>
                    <path d="M55 110 Q55 45 100 45 Q145 45 145 110 Z" fill="#F5ECD8" stroke="#301800" stroke-width="5" />
                    <rect x="50" y="105" width="100" height="22" rx="10" fill="#DC6E00" stroke="#301800" stroke-width="5" />
                    <circle cx="100" cy="80" r="11" fill="#DC6E00" />
                  </g>
                )}
                {it.id === "print" && (
                  <g>
                    <rect x="55" y="30" width="90" height="110" fill="#FFFFFF" stroke="#301800" stroke-width="5" />
                    <rect x="68" y="45" width="28" height="28" rx="8" fill="#DC6E00" />
                    <rect x="104" y="45" width="28" height="28" rx="8" fill="#301800" />
                    <rect x="68" y="81" width="28" height="28" rx="8" fill="#F5ECD8" stroke="#301800" stroke-width="3" />
                    <rect x="104" y="81" width="28" height="28" rx="8" fill="#EEA02C" />
                  </g>
                )}
              </svg>
            </div>
            <h3>{it.name}</h3>
            <p class="product-blurb">{it.blurb}</p>
            <div class="product-row">
              <span class="product-price">${it.price}</span>
              <button class="add-btn" type="button">Add to bag</button>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <aside class="bag" aria-label="Shopping bag" hidden>
    <div class="container bag-row">
      <p class="bag-line" role="status" aria-live="polite"></p>
      <button class="bag-clear" type="button">Empty bag</button>
    </div>
  </aside>
</Base>

<script>
  const bag = document.querySelector<HTMLElement>(".bag")!;
  const line = bag.querySelector<HTMLElement>(".bag-line")!;
  const items = new Map<string, { name: string; price: number; qty: number }>();

  const render = () => {
    const count = [...items.values()].reduce((n, i) => n + i.qty, 0);
    if (!count) {
      bag.hidden = true;
      return;
    }
    const total = [...items.values()].reduce((n, i) => n + i.qty * i.price, 0);
    line.textContent = `Bag: ${count} item${count > 1 ? "s" : ""} · $${total} — demo only, checkout isn't wired.`;
    bag.hidden = false;
  };

  document.querySelectorAll<HTMLElement>(".product").forEach((card) => {
    card.querySelector(".add-btn")!.addEventListener("click", () => {
      const id = card.dataset.id!;
      const cur = items.get(id) ?? { name: card.dataset.name!, price: Number(card.dataset.price), qty: 0 };
      cur.qty += 1;
      items.set(id, cur);
      render();
    });
  });
  bag.querySelector(".bag-clear")!.addEventListener("click", () => {
    items.clear();
    render();
  });
</script>

<style>
  .shop-note {
    font-size: var(--size-small);
    color: rgba(48, 24, 0, 0.65);
    margin-bottom: var(--space-4);
  }
  .shop-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }
  .product {
    background: var(--paw-white);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    padding: var(--space-3);
  }
  .product-art {
    background: var(--paw-cream);
    border-radius: var(--radius-input);
    margin-bottom: var(--space-2);
  }
  .product-art svg {
    display: block;
    width: 100%;
    height: auto;
  }
  .product-blurb {
    margin-top: 6px;
    font-size: var(--size-small);
    color: rgba(48, 24, 0, 0.75);
  }
  .product-row {
    margin-top: var(--space-2);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .product-price {
    font: 600 1.3rem/1 var(--font-display);
    color: var(--paw-orange-ink);
  }
  .add-btn {
    font: 500 0.95rem/1 var(--font-display);
    background: var(--paw-orange);
    color: var(--paw-brown);
    border: 0;
    border-radius: var(--radius-pill);
    padding: 12px 22px;
    cursor: pointer;
  }
  .add-btn:hover { background: #e97e14; }
  .bag {
    position: sticky;
    bottom: 0;
    background: var(--paw-brown);
    color: var(--paw-cream);
    padding-block: 14px;
  }
  .bag-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .bag-line { font-weight: 500; }
  .bag-clear {
    font: 500 0.9rem/1 var(--font-display);
    background: transparent;
    color: var(--paw-cream);
    border: 2px solid var(--paw-cream);
    border-radius: var(--radius-pill);
    padding: 8px 18px;
    cursor: pointer;
  }
  .bag-clear:hover {
    background: var(--paw-cream);
    color: var(--paw-brown);
  }
  @media (max-width: 900px) {
    .shop-grid { grid-template-columns: 1fr; }
  }
</style>
