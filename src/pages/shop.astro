---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import { href } from "../lib/url";
import bannerShop from "../assets/ui/banner-shop.jpg";
import { SHOP_ITEMS } from "../lib/shop-items";
---

<Base
  title="Gift shop"
  description="TinyPaws merch — tees, mugs, totes, and stickers. Every dollar of profit goes to veterinary care."
>
  <PageHero
    image={bannerShop}
    imageAlt="A calico cat rolling on her back in a teal cat bed"
    imagePosition="74% 45%"
    title="Gift shop"
    lead="Every dollar of profit goes straight to vet bills. The cats thank you — in their own way, eventually."
  />

  <aside class="bag" aria-label="Shopping bag">
    <div class="container bag-row">
      <p class="bag-line" role="status" aria-live="polite"></p>
      <a class="bag-view" href={href("/cart/")}>View bag</a>
    </div>
  </aside>

  <section class="section shop-main">
    <div class="container">
      <p class="shop-note">
        Demo shop — the bag and checkout flow work, but no payments happen
        anywhere. In the live site this connects to the rescue's store provider.
      </p>
      <h2 class="sr-only">Products</h2>
      <div class="shop-grid">
        {SHOP_ITEMS.map((it) => (
          <article class="product" data-id={it.id} data-name={it.name} data-price={it.price}>
            <div class="product-art" aria-hidden="true" set:html={it.art} />
            <h3>{it.name}</h3>
            <p class="product-blurb">{it.blurb}</p>
            <div class="product-row">
              <span class="product-price">${it.price}</span>
              <button class="add-btn" type="button">Add to bag</button>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</Base>

<script>
  import { addToBag, loadBag, bagCount, bagTotal } from "../lib/bag";

  // the bar sits flush under the sticky header, whatever its height is
  const bar = document.querySelector<HTMLElement>(".bag")!;
  const header = document.querySelector<HTMLElement>(".site-header")!;
  const pin = () => (bar.style.top = `${header.offsetHeight}px`);
  pin();
  window.addEventListener("resize", pin);

  const line = document.querySelector<HTMLElement>(".bag-line")!;
  const render = () => {
    const bag = loadBag();
    const count = bagCount(bag);
    line.textContent = count
      ? `Bag: ${count} item${count > 1 ? "s" : ""} · $${bagTotal(bag)} — demo only, no payments.`
      : "Bag is empty — demo shop, no payments.";
  };

  document.querySelectorAll<HTMLElement>(".product").forEach((card) => {
    card.querySelector(".add-btn")!.addEventListener("click", () => {
      addToBag({ id: card.dataset.id!, name: card.dataset.name!, price: Number(card.dataset.price) });
      render();
    });
  });
  render();
</script>

<style>
  .shop-main {
    padding-top: var(--space-4);
  }
  .shop-note {
    font-size: var(--size-small);
    color: rgba(48, 24, 0, 0.65);
    margin-bottom: var(--space-3);
  }
  .shop-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }
  .product {
    display: flex;
    flex-direction: column;
    background: var(--paw-white);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    padding: var(--space-3);
  }
  .product-art {
    background: var(--paw-cream);
    border-radius: var(--radius-input);
    margin-bottom: var(--space-2);
  }
  .product-art :global(svg) {
    display: block;
    width: 100%;
    height: auto;
  }
  .product-blurb {
    margin-top: 6px;
    font-size: var(--size-small);
    color: rgba(48, 24, 0, 0.75);
  }
  .product-row {
    margin-top: auto;
    padding-top: var(--space-2);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .product-price {
    font: 600 1.3rem/1 var(--font-display);
    color: var(--paw-orange-ink);
  }
  .add-btn {
    font: 500 0.95rem/1 var(--font-display);
    background: var(--paw-orange);
    color: var(--paw-brown);
    border: 0;
    border-radius: var(--radius-pill);
    padding: 12px 22px;
    cursor: pointer;
  }
  .add-btn:hover { background: #e97e14; }
  .bag {
    position: sticky;
    top: 0;
    z-index: 30;
    background: var(--paw-brown);
    color: var(--paw-cream);
    padding-block: 14px;
  }
  .bag-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .bag-line {
    font-weight: 500;
    white-space: nowrap;
    min-height: 1.65em; /* reserved before JS fills it — no layout shift */
  }
  @media (max-width: 640px) {
    .bag-line {
      font-size: 0.82rem;
      /* full-width from the start so the link never reflows mid-load */
      flex: 1 0 100%;
    }
  }
  .bag-view {
    font: 500 0.9rem/1 var(--font-display);
    color: var(--paw-cream);
    text-decoration: none;
    border: 2px solid var(--paw-cream);
    border-radius: var(--radius-pill);
    padding: 8px 18px;
  }
  .bag-view:hover {
    background: var(--paw-cream);
    color: var(--paw-brown);
  }
  @media (max-width: 900px) {
    .shop-grid { grid-template-columns: 1fr; }
  }
</style>
