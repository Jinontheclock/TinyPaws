---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Button from "../../components/Button.astro";
import CatCard from "../../components/CatCard.astro";
import CatPhoto from "../../components/CatPhoto.astro";
import { href } from "../../lib/url";

export async function getStaticPaths() {
  const cats = await getCollection("cats");
  return cats.map((cat) => ({ params: { slug: cat.id }, props: { cat, cats } }));
}
const { cat, cats } = Astro.props;
const d = cat.data;
const others = cats.filter((c) => c.id !== cat.id && c.data.status === "available").slice(0, 3);
---

<Base title={d.name} description={`Meet ${d.name}, a ${d.age} old ${d.breed.toLowerCase()} looking for a home through TinyPaws kitten rescue.`}>
  <section class="section">
    <div class="container">
      <a class="back" href={href("/adopt/")}>‹ Cats available for adoption</a>

      <div class="profile">
        <div class="profile-media">
          <div class="gallery">
            {(d.photos?.length ? d.photos : [undefined]).map((ph, i) => (
              <div class="g-main" data-i={i} hidden={i !== 0}>
                <CatPhoto
                  photo={ph}
                  photoAlt={d.photoAlt}
                  name={d.name}
                  age={d.age}
                  breed={d.breed}
                  coat={d.coat}
                  accent={d.accent}
                  preset="profile"
                  eager={i === 0}
                />
              </div>
            ))}
          </div>
          {d.photos && d.photos.length > 1 && (
            <div class="g-thumbs" role="tablist" aria-label={`Photos of ${d.name}`}>
              {d.photos.map((ph, i) => (
                <button
                  class="g-thumb"
                  type="button"
                  data-i={i}
                  role="tab"
                  aria-selected={i === 0 ? "true" : "false"}
                  aria-label={`Photo ${i + 1} of ${d.photos.length}`}
                >
                  <CatPhoto
                    photo={ph}
                    photoAlt=""
                    name={d.name}
                    age={d.age}
                    breed={d.breed}
                    coat={d.coat}
                    accent={d.accent}
                    preset="card"
                  />
                </button>
              ))}
            </div>
          )}
          {!d.photos?.length && (
            <p class="media-note">Illustrated portrait — photos coming with the next foster update.</p>
          )}
        </div>

        <div class="profile-body">
          <h1>{d.name}</h1>
          <span class={`status status--${d.status}`}>{d.status}</span>
          <dl class="facts">
            <div><dt>Sex</dt><dd>{d.sex}</dd></div>
            <div><dt>Age</dt><dd>{d.age}</dd></div>
            <div><dt>Breed</dt><dd>{d.breed}</dd></div>
            <div><dt>Location</dt><dd>{d.location}</dd></div>
            <div><dt>Days in foster</dt><dd>{d.daysInFoster}</dd></div>
          </dl>
          <ul class="traits" aria-label="Temperament">
            {d.temperament.map((t) => <li>{t}</li>)}
          </ul>
        </div>
      </div>

      <div class="about">
        <div class="about-story">
          <h2>About me</h2>
          {d.story.map((p) => <p class="story-p">{p}</p>)}
        </div>
        <div class="about-side">
          <aside class="about-medical" aria-label="Medical record">
            <h3>Medical</h3>
            <ul>
              <li>{d.medical.vaccinated ? "✓ Vaccinated" : "Vaccination in progress"}</li>
              <li>{d.medical.spayed_neutered ? "✓ Spayed / neutered" : "Spay/neuter scheduled"}</li>
            </ul>
            <p class="medical-notes">{d.medical.notes}</p>
          </aside>
        </div>
      </div>

      <div class="ctas">
        <div class="cta">
          <h3>Ready to adopt?</h3>
          <p>Start the process by sending an adoption application.</p>
          <Button href={href(`/adoption/?cat=${encodeURIComponent(d.name)}#apply`)}>
            Adoption form
          </Button>
        </div>
        <div class="cta">
          <h3>Learn about adoption</h3>
          <p>Fees, home checks, and what happens after you apply.</p>
          <Button href={href("/adoption/")} variant="outline">See the process</Button>
        </div>
        <div class="cta">
          <h3>Donate to help</h3>
          <p>Every dollar goes to food and veterinary care.</p>
          <Button href={href("/get-involved/#donate")} variant="outline">Donate</Button>
        </div>
      </div>

      {others.length > 0 && (
        <div class="others">
          <h2>Other available cats</h2>
          <div class="cat-grid">
            {others.map((c) => (
              <CatCard
                slug={c.id}
                name={c.data.name}
                age={c.data.age}
                sex={c.data.sex}
                breed={c.data.breed}
                status={c.data.status}
                coat={c.data.coat}
                accent={c.data.accent}
                temperament={c.data.temperament}
                photos={c.data.photos}
                photoAlt={c.data.photoAlt}
              />
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</Base>

<script>
  // photo gallery: thumbnails swap the main shot
  const thumbs = [...document.querySelectorAll<HTMLButtonElement>(".g-thumb")];
  const mains = [...document.querySelectorAll<HTMLElement>(".g-main")];
  for (const t of thumbs) {
    t.addEventListener("click", () => {
      const i = t.dataset.i;
      for (const m of mains) m.hidden = m.dataset.i !== i;
      for (const o of thumbs) o.setAttribute("aria-selected", o === t ? "true" : "false");
    });
  }
</script>

<style>
  .back {
    display: inline-block;
    text-decoration: none;
    font-weight: 500;
    margin-bottom: var(--space-3);
  }
  .profile {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: var(--space-4);
    align-items: start;
  }
  .profile-media {
    border-radius: var(--radius-card);
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }
  .media-note {
    font-size: var(--size-small);
    color: rgba(48, 24, 0, 0.7);
    padding: 12px 16px;
    background: var(--paw-white);
  }
  .status {
    display: inline-block;
    margin-top: 10px;
    text-transform: capitalize;
    font: 500 0.85rem/1 var(--font-body);
    padding: 7px 14px;
    border-radius: var(--radius-pill);
    background: var(--paw-cream);
  }
  .status--pending { background: var(--paw-orange); }
  .status--adopted { background: var(--paw-brown); color: var(--paw-cream); }
  .facts {
    margin: var(--space-3) 0 0;
    display: grid;
    gap: 10px;
  }
  .facts div {
    display: grid;
    grid-template-columns: 130px 1fr;
    gap: 12px;
  }
  .facts dt {
    color: rgba(48, 24, 0, 0.7);
  }
  .facts dd {
    margin: 0;
    font-weight: 500;
  }
  .traits {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: var(--space-3) 0 0;
    padding: 0;
  }
  .traits li {
    background: var(--paw-cream);
    border-radius: var(--radius-pill);
    padding: 8px 16px;
    font-size: var(--size-small);
    font-weight: 500;
  }
  .about {
    margin-top: var(--space-5);
    display: grid;
    grid-template-columns: 1.4fr 0.6fr;
    gap: var(--space-4);
    align-items: start;
  }
  .story-p {
    margin-top: var(--space-2);
  }
  .about-side {
    display: grid;
    gap: var(--space-3);
  }
  .about-medical {
    background: var(--paw-cream);
    border-radius: var(--radius-card);
    padding: var(--space-3);
  }
  .gallery {
    border-radius: var(--radius-card);
    overflow: hidden;
  }
  .g-thumbs {
    margin-top: 12px;
    display: flex;
    gap: 10px;
  }
  .g-thumb {
    all: unset;
    cursor: pointer;
    width: 76px;
    border-radius: var(--radius-input);
    overflow: hidden;
    border: 3px solid transparent;
    transition: border-color 0.15s var(--ease), opacity 0.15s var(--ease);
    opacity: 0.75;
  }
  .g-thumb:hover { opacity: 1; }
  .g-thumb[aria-selected="true"] {
    border-color: var(--paw-orange);
    opacity: 1;
  }
  .g-thumb:focus-visible {
    outline: 3px solid var(--paw-orange);
    outline-offset: 2px;
  }
  .about-medical ul {
    list-style: none;
    margin: 12px 0 0;
    padding: 0;
    display: grid;
    gap: 6px;
    font-weight: 500;
  }
  .medical-notes {
    margin-top: 12px;
    font-size: var(--size-small);
    color: rgba(48, 24, 0, 0.75);
  }
  .ctas {
    margin-top: var(--space-5);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
    text-align: center;
  }
  .cta {
    background: var(--paw-white);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    padding: var(--space-3);
    display: grid;
    justify-items: center;
    gap: 12px;
  }
  .others {
    margin-top: var(--space-6);
  }
  .cat-grid {
    margin-top: var(--space-3);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }
  @media (max-width: 900px) {
    .profile,
    .about,
    .ctas,
    .cat-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
