---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import Button from "../components/Button.astro";
import { href } from "../lib/url";
---

<Base
  title="Checkout"
  description="TinyPaws demo checkout — contact and shipping only, no payment step."
>
  <PageHero
    title="Checkout"
    lead="Demo checkout — contact and shipping only. In the live site, payment happens at the store provider."
  />

  <section class="section">
    <div class="container co-wrap">
      <div class="co-empty" hidden>
        <p>Nothing to check out — your bag is empty.</p>
        <Button href={href("/shop/")}>Back to the shop</Button>
      </div>

      <div class="co-grid">
        <form class="co-form" novalidate>
          <h2>Contact &amp; shipping</h2>
          <div class="field">
            <label for="co-name">Full name</label>
            <input id="co-name" name="name" type="text" autocomplete="name" required />
            <p class="error"></p>
          </div>
          <div class="field">
            <label for="co-email">Email</label>
            <input id="co-email" name="email" type="email" autocomplete="email" required />
            <p class="error"></p>
          </div>
          <div class="field">
            <label for="co-addr">Street address</label>
            <input id="co-addr" name="addr" type="text" autocomplete="street-address" required />
            <p class="error"></p>
          </div>
          <div class="field-row">
            <div class="field">
              <label for="co-city">City</label>
              <input id="co-city" name="city" type="text" autocomplete="address-level2" required />
              <p class="error"></p>
            </div>
            <div class="field">
              <label for="co-postal">Postal code</label>
              <input id="co-postal" name="postal" type="text" autocomplete="postal-code" required />
              <p class="error"></p>
            </div>
          </div>
          <p class="co-note">
            Demo checkout — nothing is sent or stored, and there is no payment
            step. The live site hands off to the rescue's store provider here.
          </p>
          <Button type="submit">Place order (demo)</Button>
        </form>

        <aside class="co-summary" aria-label="Order summary">
          <h2>Order summary</h2>
          <ul class="co-list"></ul>
          <p class="co-total"></p>
        </aside>
      </div>

      <div class="co-done" hidden>
        <span class="co-check" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="12" r="11" fill="#DC6E00" />
            <path d="M7 12.5 L10.5 16 L17 8.5" stroke="#301800" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
        <h2>Order confirmed!</h2>
        <p>
          Demo only — no order was placed and no payment was taken. In the live
          shop, a confirmation email would be on its way.
        </p>
        <Button href={href("/shop/")}>Back to the shop</Button>
      </div>
    </div>
  </section>
</Base>

<script>
  import { loadBag, clearBag, bagTotal } from "../lib/bag";

  const empty = document.querySelector<HTMLElement>(".co-empty")!;
  const grid = document.querySelector<HTMLElement>(".co-grid")!;
  const done = document.querySelector<HTMLElement>(".co-done")!;
  const list = document.querySelector<HTMLElement>(".co-list")!;
  const total = document.querySelector<HTMLElement>(".co-total")!;
  const form = document.querySelector<HTMLFormElement>(".co-form")!;

  const bag = loadBag();
  if (!bag.length) {
    empty.hidden = false;
    grid.hidden = true;
  } else {
    for (const i of bag) {
      const li = document.createElement("li");
      const name = document.createElement("span");
      name.textContent = `${i.name} × ${i.qty}`;
      const price = document.createElement("span");
      price.textContent = `$${i.qty * i.price}`;
      li.append(name, price);
      list.append(li);
    }
    total.textContent = `Total: $${bagTotal(bag)}`;
  }

  const validators: Record<string, (v: string) => string> = {
    name: (v) => (v.trim().length >= 2 ? "" : "Please enter your name."),
    email: (v) => (/^\S+@\S+\.\S+$/.test(v) ? "" : "Please enter a valid email address."),
    addr: (v) => (v.trim().length >= 5 ? "" : "Please enter a street address."),
    city: (v) => (v.trim().length >= 2 ? "" : "Please enter a city."),
    postal: (v) => (v.trim().length >= 4 ? "" : "Please enter a postal code."),
  };
  const check = (el: HTMLInputElement) => {
    const msg = validators[el.name]?.(el.value) ?? "";
    const field = el.closest(".field")!;
    field.classList.toggle("is-invalid", !!msg);
    field.querySelector<HTMLElement>(".error")!.textContent = msg;
    el.setAttribute("aria-invalid", msg ? "true" : "false");
    return !msg;
  };
  form.addEventListener("submit", (e) => {
    e.preventDefault();
    const fields = [...form.querySelectorAll<HTMLInputElement>("input")];
    const results = fields.map(check);
    const firstBad = fields[results.indexOf(false)];
    if (firstBad) {
      firstBad.focus();
      return;
    }
    clearBag();
    grid.hidden = true;
    done.hidden = false;
    done.scrollIntoView({ behavior: "smooth", block: "center" });
  });
  form.addEventListener(
    "blur",
    (e) => {
      const t = e.target as HTMLElement;
      if (t.matches("input")) check(t as HTMLInputElement);
    },
    true,
  );
</script>

<style>
  .co-wrap { max-width: 980px; }
  .co-empty {
    display: grid;
    justify-items: start;
    gap: var(--space-3);
  }
  .co-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-4);
    align-items: start;
  }
  .co-form {
    display: grid;
    gap: var(--space-2);
  }
  .field { display: grid; gap: 6px; }
  .field-row {
    display: grid;
    grid-template-columns: 1.4fr 0.6fr;
    gap: var(--space-2);
  }
  label { font: 500 1rem/1.3 var(--font-display); }
  input {
    width: 100%;
    min-width: 0;
    font: 400 1rem/1.4 var(--font-body);
    color: var(--paw-brown);
    background: var(--paw-white);
    border: 2px solid rgba(48, 24, 0, 0.18);
    border-radius: var(--radius-input);
    padding: 13px 16px;
  }
  input:focus {
    outline: none;
    border-color: var(--paw-orange);
  }
  .field.is-invalid input { border-color: #b3261e; }
  .error {
    min-height: 1.1em;
    font-size: var(--size-small);
    color: #b3261e;
  }
  .co-note {
    font-size: var(--size-small);
    color: rgba(48, 24, 0, 0.65);
  }
  .co-summary {
    background: var(--paw-cream);
    border-radius: var(--radius-card);
    padding: var(--space-3);
    position: sticky;
    top: 92px;
  }
  .co-list {
    list-style: none;
    margin: var(--space-2) 0 0;
    padding: 0;
    display: grid;
    gap: 8px;
  }
  .co-list li {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    font-size: var(--size-small);
  }
  .co-total {
    margin-top: var(--space-2);
    padding-top: var(--space-2);
    border-top: 1px solid rgba(48, 24, 0, 0.15);
    font: 600 1.3rem/1 var(--font-display);
  }
  .co-done {
    display: grid;
    justify-items: center;
    text-align: center;
    gap: var(--space-2);
    max-width: 480px;
    margin-inline: auto;
    padding-block: var(--space-4);
  }
  .co-check svg {
    width: 72px;
    height: 72px;
  }
  @media (max-width: 900px) {
    .co-grid { grid-template-columns: 1fr; }
    .co-summary { position: static; order: -1; }
  }
</style>
