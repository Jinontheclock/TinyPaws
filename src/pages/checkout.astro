---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import Button from "../components/Button.astro";
import { href } from "../lib/url";
import { artById } from "../lib/shop-items";
---

<Base
  title="Checkout"
  description="TinyPaws demo checkout — shipping and a payment-method choice, with no real payment anywhere."
>
  <PageHero
    title="Checkout"
    lead="Demo checkout — pick a payment method, but no card details are ever asked for and nothing is charged."
  />

  <section class="section">
    <div class="container co-wrap" data-art={JSON.stringify(artById)}>
      <ol class="co-steps" aria-label="Checkout progress">
        <li class="step-done"><span class="step-dot" aria-hidden="true">✓</span> Bag</li>
        <li class="step-now" aria-current="step"><span class="step-dot" aria-hidden="true">2</span> Details</li>
        <li class="step-next"><span class="step-dot" aria-hidden="true">3</span> Confirmation</li>
      </ol>

      <div class="co-empty" hidden>
        <p>Nothing to check out — your bag is empty.</p>
        <Button href={href("/shop/")}>Back to the shop</Button>
      </div>

      <div class="co-grid" hidden>
        <form class="co-form" novalidate>
          <h2>Contact &amp; shipping</h2>
          <div class="field">
            <label for="co-name">Full name</label>
            <input id="co-name" name="name" type="text" autocomplete="name" required />
            <p class="error"></p>
          </div>
          <div class="field">
            <label for="co-email">Email</label>
            <input id="co-email" name="email" type="email" autocomplete="email" required />
            <p class="error"></p>
          </div>
          <div class="field">
            <label for="co-addr">Street address</label>
            <input id="co-addr" name="addr" type="text" autocomplete="street-address" required />
            <p class="error"></p>
          </div>
          <div class="field-row">
            <div class="field">
              <label for="co-city">City</label>
              <input id="co-city" name="city" type="text" autocomplete="address-level2" required />
              <p class="error"></p>
            </div>
            <div class="field">
              <label for="co-postal">Postal code</label>
              <input id="co-postal" name="postal" type="text" autocomplete="postal-code" required />
              <p class="error"></p>
            </div>
          </div>

          <h2 class="pay-head">Payment method</h2>
          <div class="pay-options" role="radiogroup" aria-label="Payment method">
            <label class="pay-pill">
              <input type="radio" name="pay" value="applepay" required />
              <span><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15.8 5.6c.7-.9 1.2-2.1 1-3.3-1 .1-2.2.7-2.9 1.6-.6.8-1.2 2-1 3.2 1.1 0 2.2-.6 2.9-1.5Zm1.9 6.9c0-2.2 1.8-3.2 1.9-3.3-1-1.5-2.6-1.7-3.2-1.7-1.4-.1-2.6.8-3.3.8-.7 0-1.7-.8-2.9-.8-1.5 0-2.8.9-3.6 2.2-1.5 2.6-.4 6.5 1.1 8.6.7 1 1.6 2.2 2.7 2.1 1.1 0 1.5-.7 2.8-.7s1.7.7 2.9.7c1.2 0 2-1 2.7-2.1.9-1.2 1.2-2.4 1.2-2.5-.1 0-2.3-.9-2.3-3.3Z" fill="currentColor"/></svg> Apple Pay</span>
            </label>
            <label class="pay-pill">
              <input type="radio" name="pay" value="card" />
              <span><svg viewBox="0 0 24 24" aria-hidden="true"><rect x="2" y="5" width="20" height="14" rx="3" fill="none" stroke="currentColor" stroke-width="2"/><path d="M2 9.5h20" stroke="currentColor" stroke-width="2"/><path d="M6 14.5h5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg> Credit card — Visa / Mastercard</span>
            </label>
            <label class="pay-pill">
              <input type="radio" name="pay" value="paypal" />
              <span><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 21 9.2 5.5A2 2 0 0 1 11.2 4h4.3c2.8 0 4.6 1.7 4.2 4.3-.4 3-2.5 4.7-5.4 4.7h-2.1a1 1 0 0 0-1 .9L10.4 21H7Z" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg> PayPal</span>
            </label>
          </div>
          <p class="error pay-error" role="alert"></p>

          <p class="co-note">
            Demo checkout — no card numbers or account details are asked for,
            nothing is sent or stored, and no payment happens. The live site
            hands off to the store provider at this step.
          </p>
          <Button type="submit">Place order (demo)</Button>
        </form>

        <aside class="co-summary" aria-label="Order summary">
          <h2>Order summary</h2>
          <ul class="co-list"></ul>
          <dl class="sum-rows">
            <div><dt>Subtotal</dt><dd class="co-subtotal"></dd></div>
            <div><dt>Shipping</dt><dd>Free — local pickup</dd></div>
            <div class="sum-total-row"><dt>Total</dt><dd class="co-total"></dd></div>
          </dl>
        </aside>
      </div>

      <div class="co-done" hidden>
        <span class="co-check" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="12" r="11" fill="#DC6E00" />
            <path d="M7 12.5 L10.5 16 L17 8.5" stroke="#301800" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </span>
        <h2>Order confirmed!</h2>
        <p>
          Demo only — no order was placed and no payment was taken. In the live
          shop, a confirmation email would be on its way.
        </p>
        <Button href={href("/shop/")}>Back to the shop</Button>
      </div>
    </div>
  </section>
</Base>

<script>
  import { loadBag, clearBag, bagTotal } from "../lib/bag";

  const wrap = document.querySelector<HTMLElement>(".co-wrap")!;
  const art: Record<string, string> = JSON.parse(wrap.dataset.art!);
  const steps = wrap.querySelector<HTMLElement>(".co-steps")!;
  const empty = wrap.querySelector<HTMLElement>(".co-empty")!;
  const grid = wrap.querySelector<HTMLElement>(".co-grid")!;
  const done = wrap.querySelector<HTMLElement>(".co-done")!;
  const list = wrap.querySelector<HTMLElement>(".co-list")!;
  const subEl = wrap.querySelector<HTMLElement>(".co-subtotal")!;
  const totalEl = wrap.querySelector<HTMLElement>(".co-total")!;
  const form = wrap.querySelector<HTMLFormElement>(".co-form")!;

  const bag = loadBag();
  if (!bag.length) {
    empty.hidden = false;
  } else {
    grid.hidden = false;
    for (const i of bag) {
      const li = document.createElement("li");
      const thumb = document.createElement("span");
      thumb.className = "co-thumb";
      thumb.setAttribute("aria-hidden", "true");
      thumb.innerHTML = art[i.id] ?? "";
      const name = document.createElement("span");
      name.className = "co-name";
      name.textContent = `${i.name} × ${i.qty}`;
      const price = document.createElement("span");
      price.className = "co-price";
      price.textContent = `$${i.qty * i.price}`;
      li.append(thumb, name, price);
      list.append(li);
    }
    const total = bagTotal(bag);
    subEl.textContent = `$${total}`;
    totalEl.textContent = `$${total}`;
  }

  const validators: Record<string, (v: string) => string> = {
    name: (v) => (v.trim().length >= 2 ? "" : "Please enter your name."),
    email: (v) => (/^\S+@\S+\.\S+$/.test(v) ? "" : "Please enter a valid email address."),
    addr: (v) => (v.trim().length >= 5 ? "" : "Please enter a street address."),
    city: (v) => (v.trim().length >= 2 ? "" : "Please enter a city."),
    postal: (v) => (v.trim().length >= 4 ? "" : "Please enter a postal code."),
  };
  const check = (el: HTMLInputElement) => {
    const msg = validators[el.name]?.(el.value) ?? "";
    const field = el.closest(".field");
    if (!field) return true;
    field.classList.toggle("is-invalid", !!msg);
    field.querySelector<HTMLElement>(".error")!.textContent = msg;
    el.setAttribute("aria-invalid", msg ? "true" : "false");
    return !msg;
  };

  form.addEventListener("submit", (e) => {
    e.preventDefault();
    const fields = [...form.querySelectorAll<HTMLInputElement>('input:not([type="radio"])')];
    const results = fields.map(check);
    const payPicked = !!form.querySelector<HTMLInputElement>('input[name="pay"]:checked');
    form.querySelector<HTMLElement>(".pay-error")!.textContent = payPicked
      ? ""
      : "Please choose a payment method.";
    const firstBad = fields[results.indexOf(false)];
    if (firstBad) {
      firstBad.focus();
      return;
    }
    if (!payPicked) return;
    clearBag();
    grid.hidden = true;
    done.hidden = false;
    steps.querySelector(".step-now")!.classList.replace("step-now", "step-done");
    const last = steps.querySelector(".step-next")!;
    last.classList.replace("step-next", "step-now");
    last.setAttribute("aria-current", "step");
    done.scrollIntoView({ behavior: "smooth", block: "center" });
  });
  form.addEventListener(
    "blur",
    (e) => {
      const t = e.target as HTMLElement;
      if (t.matches('input:not([type="radio"])')) check(t as HTMLInputElement);
    },
    true,
  );
</script>

<style>
  .co-wrap { max-width: 1040px; }
  /* checkout progress bar */
  .co-steps {
    list-style: none;
    margin: 0 0 var(--space-4);
    padding: 0;
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .co-steps li {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font: 500 1rem/1 var(--font-display);
  }
  .co-steps li:not(:last-child)::after {
    content: "";
    width: 46px;
    height: 2px;
    background: rgba(48, 24, 0, 0.2);
    margin-left: var(--space-2);
  }
  .step-dot {
    display: inline-grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    font-size: 0.9rem;
  }
  .step-done .step-dot { background: var(--paw-brown); color: var(--paw-cream); }
  .step-now .step-dot { background: var(--paw-orange); color: var(--paw-brown); }
  .step-next { color: rgba(48, 24, 0, 0.7); }
  .step-next .step-dot { background: var(--paw-cream); }
  .co-empty {
    display: grid;
    justify-items: start;
    gap: var(--space-3);
  }
  .co-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-4);
    align-items: start;
  }
  .co-form { display: grid; gap: var(--space-2); }
  .field { display: grid; gap: 6px; }
  .field-row {
    display: grid;
    grid-template-columns: 1.4fr 0.6fr;
    gap: var(--space-2);
  }
  label { font: 500 1rem/1.3 var(--font-display); }
  input {
    width: 100%;
    min-width: 0;
    font: 400 1rem/1.4 var(--font-body);
    color: var(--paw-brown);
    background: var(--paw-white);
    border: 2px solid rgba(48, 24, 0, 0.18);
    border-radius: var(--radius-input);
    padding: 13px 16px;
  }
  input:focus {
    outline: none;
    border-color: var(--paw-orange);
  }
  .field.is-invalid input { border-color: #b3261e; }
  .error {
    min-height: 1.1em;
    font-size: var(--size-small);
    color: #b3261e;
  }
  .pay-head { margin-top: var(--space-2); }
  .pay-options {
    display: grid;
    gap: 10px;
  }
  .pay-pill {
    position: relative;
    cursor: pointer;
  }
  .pay-pill input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .pay-pill span {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--paw-white);
    border: 2px solid rgba(48, 24, 0, 0.18);
    border-radius: var(--radius-input);
    padding: 14px 18px;
    font-weight: 500;
    transition: border-color 0.15s var(--ease), background 0.15s var(--ease);
  }
  .pay-pill svg { width: 22px; height: 22px; flex: none; }
  .pay-pill:hover span { border-color: rgba(48, 24, 0, 0.4); }
  .pay-pill:has(input:checked) span {
    border-color: var(--paw-orange);
    background: var(--paw-cream);
  }
  .pay-pill:has(input:focus-visible) span {
    outline: 3px solid var(--paw-orange);
    outline-offset: 1px;
  }
  .co-note {
    font-size: var(--size-small);
    color: rgba(48, 24, 0, 0.65);
  }
  .co-summary {
    background: var(--paw-cream);
    border-radius: var(--radius-card);
    padding: var(--space-3);
    position: sticky;
    top: 92px;
  }
  .co-list {
    list-style: none;
    margin: var(--space-2) 0 0;
    padding: 0;
    display: grid;
    gap: 10px;
  }
  .co-list :global(li) {
    display: grid;
    grid-template-columns: 56px 1fr auto;
    align-items: center;
    gap: 12px;
    font-size: var(--size-small);
  }
  :global(.co-thumb) {
    width: 56px;
    height: 44px;
    background: var(--paw-white);
    border-radius: 10px;
    overflow: hidden;
  }
  :global(.co-thumb svg) {
    display: block;
    width: 100%;
    height: 100%;
  }
  :global(.co-price) { font-weight: 600; }
  .sum-rows {
    margin: var(--space-3) 0 0;
    display: grid;
    gap: 10px;
  }
  .sum-rows div {
    display: flex;
    justify-content: space-between;
    gap: 12px;
  }
  .sum-rows dt { color: rgba(48, 24, 0, 0.7); }
  .sum-rows dd { margin: 0; font-weight: 600; }
  .sum-total-row {
    padding-top: 10px;
    border-top: 1px solid rgba(48, 24, 0, 0.15);
  }
  .sum-total-row dt,
  .sum-total-row dd {
    font: 600 1.2rem/1 var(--font-display);
    color: var(--paw-brown);
  }
  .co-done {
    display: grid;
    justify-items: center;
    text-align: center;
    gap: var(--space-2);
    max-width: 480px;
    margin-inline: auto;
    padding-block: var(--space-4);
  }
  .co-check svg { width: 72px; height: 72px; }
  @media (max-width: 900px) {
    .co-grid { grid-template-columns: 1fr; }
    .co-summary { position: static; order: -1; }
  }
</style>
