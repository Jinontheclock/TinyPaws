---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import bannerInvolve from "../assets/ui/banner-involve.jpg";
import Button from "../components/Button.astro";
import { Image } from "astro:assets";
import volOnboard from "../assets/ui/people-onboarding.jpg";
import volFun from "../assets/ui/people-shift.jpg";
import volCommunity from "../assets/ui/people-community.jpg";
import exp1 from "../assets/ui/people-exp-1.jpg";
import exp2 from "../assets/ui/people-exp-2.jpg";
import exp3 from "../assets/ui/people-exp-3.jpg";
import { href } from "../lib/url";

/* the hi-fi "What you can expect" band: circular photos, orange titles */
const expectations = [
  {
    title: "Onboarding",
    text: "An orientation night every month covers handling, cleaning protocols, and what a shift actually looks like. No cat-handling experience needed — just reliability.",
    img: volOnboard,
    alt: "A volunteer gently cradling a tiny tabby kitten against his shoulder",
  },
  {
    title: "Lots of fun — and lots of pets",
    text: "Adoption-day setup, transport runs between fosters and the vet, photography, and events. Every role comes with more kitten time than you're prepared for.",
    img: volFun,
    alt: "A volunteer at the clinic table with two wobbly foster kittens",
  },
  {
    title: "Building community",
    text: "You'll join a group chat of fosters and volunteers who celebrate every adoption together. Students welcome — we sign off volunteer hours.",
    img: volCommunity,
    alt: "A smiling volunteer holding a brown tabby cat in her arms",
  },
];

/* the hi-fi "Volunteer Experiences" rows: a foster photo and a short
   first-person note (demo testimonials) */
const experiences = [
  {
    name: "Maya, 29",
    img: exp1,
    alt: "Maya smiling with two foster kittens, one cream and one grey, in her arms",
    text: "My first litter was two bottle babies who screamed all night. Eight weeks later I handed them to their new family and cried in the parking lot — then signed up for the next litter that evening. Fostering is the best worst idea I've ever had.",
  },
  {
    name: "Priya, 34",
    img: exp2,
    alt: "Priya holding a calico foster cat against her shoulder at the clinic",
    text: "I started as an adoption-day volunteer because I couldn't have cats in my rental. Two years and one lease change later, I've fostered eleven cats and failed exactly once — she's asleep on my couch right now.",
  },
  {
    name: "Dan, 44",
    img: exp3,
    alt: "Dan holding a small grey foster kitten up to the camera",
    text: "I do the vet runs. It's an hour a week of driving with a meowing passenger, and it's somehow the calmest part of my schedule. My kids keep score of how many cats Dad has chauffeured — we're at 63.",
  },
];

/* the hi-fi Donate frame lists a five-part supply wishlist — kept here
   with items a foster-based rescue actually runs out of */
const wishlist = [
  {
    title: "Food Items",
    icon: '<path d="M4 13 h16 a8 8 0 0 1 -16 0 Z"/><circle cx="9" cy="9.5" r="1.1"/><circle cx="13.2" cy="7.8" r="1.1"/><circle cx="16.2" cy="10" r="1.1"/>',
    items: [
      "Kitten wet food (pâté — young kittens can't crunch yet)",
      "Kitten formula (KMR) for bottle babies",
      "Kitten dry food for the older litters",
      "Lickable treats for socializing shy cats",
    ],
  },
  {
    title: "Toys and Enrichment",
    icon: '<circle cx="11" cy="12" r="7"/><path d="M5 9.5 c4 -1 8 -1 11.5 1 M4.7 14 c4 1.3 8.6 1.2 12.3 -0.8 M11 5 c-2.2 4 -2.2 10 0 14"/><path d="M17.5 14.5 l3.5 6"/>',
    items: [
      "Wand toys and crinkle balls",
      "Scratching posts and cardboard scratchers",
      "Cat trees (gently used is perfect)",
      "Puzzle feeders for the clever ones",
    ],
  },
  {
    title: "Grooming and Care",
    icon: '<rect x="5" y="4" width="14" height="6.5" rx="3.2"/><path d="M8.5 10.5 v2.5 M12 10.5 v2.5 M15.5 10.5 v2.5"/><path d="M12 15.5 v5"/>',
    items: [
      "Unscented wipes and cotton pads",
      "Flea combs and soft brushes",
      "Nail clippers (kitten size)",
      "Kitten-safe shampoo",
    ],
  },
  {
    title: "Daily Needs",
    icon: '<path d="M4.5 8.5 h15 v9.5 a2 2 0 0 1 -2 2 h-11 a2 2 0 0 1 -2 -2 Z"/><path d="M4.5 8.5 L7 4.5 h10 l2.5 4"/><path d="M10 12.5 h4"/>',
    items: [
      "Clumping litter and low-sided litter boxes",
      "Fleece blankets and washable bedding",
      "Heating pads for orphaned newborns",
      "Carriers for vet runs and adoption days",
    ],
  },
  {
    title: "Technology Donations",
    icon: '<rect x="3" y="5" width="18" height="11.5" rx="2"/><path d="M9 21 h6 M12 16.5 V21"/>',
    items: [
      "Digital kitchen scales — daily weigh-ins catch problems early",
      "Baby monitors or spare webcams for foster rooms",
      "Pet-store gift cards for whatever the week brings",
    ],
  },
];
---

<Base
  title="Get involved"
  description="Foster a litter, volunteer at events, or donate to cover veterinary care — three ways to keep TinyPaws running."
>
  <PageHero
    image={bannerInvolve}
    imageAlt="An orange-and-white cat asleep on a soft white bed"
    title="Get involved"
    lead="TinyPaws has no shelter building — just people. Fosters, volunteers, and donors are the whole operation."
  />

  <section class="section" id="foster">
    <div class="container split">
      <div>
        <h2>Foster a litter</h2>
        <p class="body-gap">
          Fostering means giving kittens a spare room and a routine for two to
          eight weeks while they grow big enough for adoption. We cover food,
          litter, supplies, and every vet visit — you supply the safe space and
          the socializing.
        </p>
        <ul class="ticks">
          <li>All supplies and vet costs covered</li>
          <li>A mentor foster on call for every placement</li>
          <li>Works around your schedule — say no anytime</li>
        </ul>
        <Button href={href("/events/")}>Join a foster orientation</Button>
      </div>
      <div class="panel panel--cream" aria-hidden="true">
        <p class="big-stat">2–8</p>
        <p>weeks per placement, start to adoption</p>
      </div>
    </div>
  </section>

  <section class="section expect-band" id="volunteer">
    <div class="container">
      <h2 class="center expect-head">Volunteer — what you can expect</h2>
      <p class="expect-lead">
        About four hours a month keeps a shift covered. Here's what those
        hours actually look like.
      </p>
      <div class="expect-rows">
        {expectations.map((x, i) => (
          <div class="expect-row" data-reveal style={`transition-delay:${i * 0.08}s`}>
            <span class="expect-photo">
              <Image src={x.img} alt={x.alt} widths={[280]} format="webp" loading="lazy" />
            </span>
            <div>
              <h3>{x.title}</h3>
              <p>{x.text}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="expect-cta">
        <Button href={href("/events/")}>See upcoming orientations</Button>
      </div>
    </div>
  </section>

  <section class="section section--cream" id="experiences">
    <div class="container">
      <h2 class="center">Volunteer experiences</h2>
      <div class="exp-rows">
        {experiences.map((e, i) => (
          <div class="exp-row" data-reveal style={`transition-delay:${i * 0.08}s`}>
            <Image class="exp-photo" src={e.img} alt={e.alt} widths={[420]} format="webp" loading="lazy" />
            <div>
              <h3>{e.name}</h3>
              <p>{e.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="donate">
    <div class="container donate-wrap">
      <h2>Donate</h2>
      <p class="body-gap">
        Veterinary care is our biggest cost — a single litter's vaccines,
        deworming, and spay/neuter run about $900. Donations go there first,
        then to food and supplies.
      </p>
      <form class="donate-form">
        <div class="donate-tiers" role="radiogroup" aria-label="Donation amount">
          <label class="tier">
            <input type="radio" name="amount" value="25" required />
            <p class="tier-amt">$25</p>
            <p>vaccinates one kitten</p>
          </label>
          <label class="tier">
            <input type="radio" name="amount" value="80" />
            <p class="tier-amt">$80</p>
            <p>covers a spay or neuter</p>
          </label>
          <label class="tier">
            <input type="radio" name="amount" value="150" />
            <p class="tier-amt">$150</p>
            <p>funds a litter's first month</p>
          </label>
        </div>
        <div class="donate-custom">
          <label for="donate-other">Or another amount</label>
          <div class="donate-custom-row">
            <span class="donate-currency" aria-hidden="true">$</span>
            <input id="donate-other" name="other" type="number" min="1" max="10000" inputmode="numeric" placeholder="50" />
          </div>
        </div>
        <p class="donate-note">
          This demo doesn't process payments. In the live site this button leads
          to the rescue's payment provider.
        </p>
        <button class="donate-submit" type="submit">Donate (demo)</button>
      </form>
      <div class="donate-thanks" role="status" aria-live="polite" hidden>
        <h3>Thank you!</h3>
        <p class="donate-thanks-line"></p>
        <p class="donate-thanks-demo">
          Demo only — no payment was processed and no details were collected.
        </p>
        <button class="donate-again" type="button">Choose a different amount</button>
      </div>
    </div>
  </section>

  <section class="section section--taupe" id="wishlist">
    <div class="container">
      <h2 class="center wishlist-head">Our Wishlist</h2>
      <p class="wishlist-lead">
        Prefer to give supplies instead of money? These are the things we run
        out of fastest. New or gently used, everything goes straight into
        foster homes — bring donations to any adoption event, or message us to
        arrange a pickup.
      </p>
      <div class="wish-rows">
        {wishlist.map((w, i) => (
          <div class="wish-row" data-reveal style={`transition-delay:${i * 0.06}s`}>
            <div class="wish-cat">
              <h3>{w.title}</h3>
              <span class="wish-icon" aria-hidden="true">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.7"
                  stroke-linejoin="round"
                  stroke-linecap="round"
                  set:html={w.icon}
                />
              </span>
            </div>
            <ul class="wish-items">
              {w.items.map((it) => (
                <li>{it}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <p class="wishlist-note">
        Please skip open food bags and scented litter — sensitive kitten noses
        say thank you.
      </p>
    </div>
  </section>
</Base>

<script>
  const form = document.querySelector<HTMLFormElement>(".donate-form")!;
  const thanks = document.querySelector<HTMLElement>(".donate-thanks")!;
  const line = thanks.querySelector<HTMLElement>(".donate-thanks-line")!;
  const other = form.querySelector<HTMLInputElement>("#donate-other")!;
  const radios = [...form.querySelectorAll<HTMLInputElement>('input[name="amount"]')];

  const IMPACT: Record<string, string> = {
    "25": "vaccinates one kitten",
    "80": "covers a spay or neuter",
    "150": "funds a litter's first month",
  };

  // typing a custom amount releases the tier requirement, and vice versa
  other.addEventListener("input", () => {
    radios.forEach((r) => {
      r.required = other.value.trim() === "";
      if (other.value.trim() !== "") r.checked = false;
    });
  });
  radios.forEach((r) =>
    r.addEventListener("change", () => {
      if (r.checked) other.value = "";
    }),
  );

  form.addEventListener("submit", (e) => {
    e.preventDefault();
    if (!form.reportValidity()) return;
    const picked = radios.find((r) => r.checked)?.value;
    const amount = picked ?? String(Math.round(Number(other.value)));
    line.textContent = IMPACT[amount]
      ? `A real $${amount} donation ${IMPACT[amount]}.`
      : `A real $${amount} donation goes straight to veterinary care, food, and supplies.`;
    form.hidden = true;
    thanks.hidden = false;
    thanks.scrollIntoView({ behavior: "smooth", block: "center" });
  });

  thanks.querySelector(".donate-again")!.addEventListener("click", () => {
    form.reset();
    radios.forEach((r) => (r.required = true));
    thanks.hidden = true;
    form.hidden = false;
    form.scrollIntoView({ behavior: "smooth", block: "center" });
  });
</script>

<style>
  .split {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-5);
    align-items: center;
  }
  .split--flip {
    grid-template-columns: 0.8fr 1.2fr;
  }
  .body-gap {
    margin-top: var(--space-2);
  }
  .ticks {
    list-style: none;
    margin: var(--space-3) 0 var(--space-4);
    padding: 0;
    display: grid;
    gap: 10px;
  }
  .ticks li {
    padding-left: 30px;
    position: relative;
    font-weight: 500;
  }
  .ticks li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--paw-orange-ink);
    font-weight: 700;
  }
  .panel {
    border-radius: var(--radius-card);
    padding: var(--space-4);
    text-align: center;
  }
  .panel--cream { background: var(--paw-cream); }
  .panel--white { background: var(--paw-white); box-shadow: var(--shadow-card); }
  .big-stat {
    font: 600 3.4rem/1 var(--font-display);
    color: var(--paw-orange-ink);
  }
  .panel p:last-child {
    margin-top: 8px;
    margin-inline: auto;
    max-width: 22ch;
  }
  .donate-wrap { max-width: 760px; }
  .donate-tiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
    margin-block: var(--space-4);
  }
  .tier {
    background: var(--paw-cream);
    border: 2px solid transparent;
    border-radius: var(--radius-card);
    padding: var(--space-3);
    text-align: center;
    cursor: pointer;
    display: block;
  }
  .tier:has(input:checked) {
    border-color: var(--paw-orange);
    background: var(--paw-white);
    box-shadow: var(--shadow-card);
  }
  .tier input {
    accent-color: var(--paw-orange);
    display: block;
    margin: 0 auto 10px;
  }
  .tier-amt {
    font: 600 2.2rem/1 var(--font-display);
    color: var(--paw-brown);
  }
  .tier p:last-child { margin: 8px auto 0; }
  .donate-custom label {
    font-weight: 500;
    display: block;
    margin-bottom: 8px;
  }
  .donate-custom-row {
    display: flex;
    align-items: center;
    gap: 10px;
    max-width: 220px;
  }
  .donate-currency {
    font: 600 1.2rem/1 var(--font-display);
    color: var(--paw-orange-ink);
  }
  .donate-custom input {
    width: 100%;
    font: 400 1rem/1.4 var(--font-body);
    color: var(--paw-brown);
    padding: 13px 16px;
    border: 2px solid rgba(48, 24, 0, 0.18);
    border-radius: var(--radius-input);
    background: var(--paw-white);
  }
  .donate-custom input:focus {
    outline: none;
    border-color: var(--paw-orange);
  }
  .donate-note {
    font-size: var(--size-small);
    color: rgba(48, 24, 0, 0.65);
    margin-block: var(--space-3);
  }
  .donate-submit {
    font: 500 var(--size-button)/1 var(--font-display);
    background: var(--paw-orange);
    color: var(--paw-brown);
    border: 0;
    border-radius: var(--radius-pill);
    padding: 16px 34px;
    cursor: pointer;
  }
  .donate-submit:hover { background: #e97e14; }
  .donate-thanks {
    margin-top: var(--space-4);
    background: var(--paw-brown);
    color: var(--paw-cream);
    border-radius: var(--radius-card);
    padding: var(--space-4);
  }
  .donate-thanks h3 {
    color: var(--paw-cream);
    font-size: 1.6rem;
  }
  .donate-thanks-line { margin-top: 10px; }
  .donate-thanks-demo {
    margin-top: 8px;
    font-size: var(--size-small);
    opacity: 0.8;
  }
  .donate-again {
    margin-top: var(--space-3);
    font: 500 1rem/1 var(--font-display);
    background: transparent;
    color: var(--paw-cream);
    border: 2px solid var(--paw-cream);
    border-radius: var(--radius-pill);
    padding: 12px 24px;
    cursor: pointer;
  }
  .donate-again:hover {
    background: var(--paw-cream);
    color: var(--paw-brown);
  }
  .center { text-align: center; }
  /* the hi-fi volunteer band: dark brown, circular photos, orange titles */
  .expect-band { background: var(--paw-brown); }
  .expect-head { color: var(--paw-cream); }
  .expect-lead {
    margin: var(--space-2) auto 0;
    max-width: 56ch;
    text-align: center;
    color: var(--paw-cream);
    opacity: 0.85;
  }
  .expect-rows {
    margin-top: var(--space-5);
    display: grid;
    gap: var(--space-4);
    max-width: 760px;
    margin-inline: auto;
  }
  .expect-row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: var(--space-4);
    align-items: center;
  }
  .expect-photo {
    display: block;
    width: 140px;
    height: 140px;
    border-radius: 50%;
    overflow: hidden;
    border: 5px solid var(--paw-cream);
    transition: transform 0.3s var(--ease);
  }
  .expect-row:hover .expect-photo {
    transform: scale(1.05) rotate(-2deg);
  }
  .expect-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .expect-row h3 {
    color: #ffe4bc;
    font-size: 1.25rem;
  }
  .expect-row p {
    margin-top: 8px;
    color: var(--paw-cream);
    opacity: 0.92;
  }
  .expect-cta {
    margin-top: var(--space-5);
    text-align: center;
  }
  /* the hi-fi volunteer experiences: photo cards with short testimonials */
  .exp-rows {
    margin-top: var(--space-5);
    display: grid;
    gap: var(--space-4);
    max-width: 860px;
    margin-inline: auto;
  }
  .exp-row {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: var(--space-4);
    align-items: center;
    background: var(--paw-white);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    padding: var(--space-3);
  }
  .exp-photo {
    width: 100%;
    height: 220px;
    object-fit: cover;
    border-radius: var(--radius-input);
  }
  .exp-row h3 {
    color: var(--paw-orange-ink);
    font-size: 1.15rem;
  }
  .exp-row p {
    margin-top: 8px;
    max-width: 58ch;
  }
  /* the hi-fi wishlist band: taupe, icon circles left, item lists right */
  .wishlist-head { color: var(--paw-white); }
  .wishlist-lead {
    margin: var(--space-2) auto 0;
    max-width: 64ch;
    text-align: center;
    color: var(--paw-white);
  }
  .wish-rows {
    margin-top: var(--space-5);
    display: grid;
    gap: var(--space-4);
    max-width: 820px;
    margin-inline: auto;
  }
  .wish-row {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--space-4);
    align-items: center;
  }
  .wish-cat {
    display: grid;
    justify-items: center;
    gap: var(--space-2);
    text-align: center;
  }
  .wish-cat h3 {
    color: #ffe4bc;
    font-size: 1.2rem;
  }
  .wish-icon {
    display: inline-grid;
    place-items: center;
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background: var(--paw-cream);
    color: var(--paw-brown);
    box-shadow: 0 8px 22px rgba(48, 24, 0, 0.25);
    transition: transform 0.3s var(--ease);
  }
  .wish-row:hover .wish-icon {
    transform: translateY(-5px) rotate(-3deg);
  }
  .wish-icon svg {
    width: 44px;
    height: 44px;
  }
  .wish-items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 10px;
  }
  .wish-items li {
    position: relative;
    padding-left: 24px;
    color: var(--paw-white);
  }
  .wish-items li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.5em;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--paw-orange);
  }
  .wishlist-note {
    margin-top: var(--space-5);
    text-align: center;
    font-size: var(--size-small);
    color: var(--paw-white);
    max-width: none;
  }
  @media (max-width: 900px) {
    .split,
    .split--flip {
      grid-template-columns: 1fr;
    }
    .split--flip .panel { order: 2; }
    /* tiers stay on one row — just tighter */
    .donate-tiers { gap: 10px; }
    .tier { padding: var(--space-2) 10px; }
    .tier-amt { font-size: 1.5rem; }
    .tier p:last-child { font-size: 0.8rem; }
  }
  @media (max-width: 720px) {
    .exp-row {
      grid-template-columns: 1fr;
    }
    .exp-photo { height: 240px; }
    .expect-row,
    .wish-row {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: center;
    }
    .expect-row p { margin-inline: auto; }
    .wish-items { justify-self: start; }
  }
</style>
