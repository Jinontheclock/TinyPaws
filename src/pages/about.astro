---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import Button from "../components/Button.astro";
import { Image } from "astro:assets";
import fosterFamily from "../assets/ui/foster-family.jpg";

/* mirrors the hi-fi About us: Our Story (full text) → Our Mission
   (five pillars with icons) → contact form. Story copy and the five
   mission items are verbatim from the hi-fi frames. */
const mission = [
  {
    title: "Rescue & Rehabilitate",
    text: "We provide immediate care and shelter to stray, abandoned, and at-risk cats, ensuring they receive the medical attention, safety, and love they need to heal.",
    icon: '<path d="M12 20 C7.5 16.2 4.5 13.3 4.5 10.3 A3.9 3.9 0 0 1 12 8.6 A3.9 3.9 0 0 1 19.5 10.3 C19.5 13.3 16.5 16.2 12 20 Z"/><path d="M12 10.6 v4.2 M9.9 12.7 h4.2"/>',
  },
  {
    title: "Foster-based support",
    text: "Every cat in our care is placed in a loving foster home, where they can thrive emotionally and physically until they're ready for adoption.",
    icon: '<path d="M12 3 L21 10 V21 H3 V10 Z"/><path d="M12 17.6 C10.2 16 9.1 14.9 9.1 13.8 A1.75 1.75 0 0 1 12 12.8 A1.75 1.75 0 0 1 14.9 13.8 C14.9 14.9 13.8 16 12 17.6 Z"/>',
  },
  {
    title: "Forever Home",
    text: "We match each cat with a carefully chosen forever family to ensure a lifelong, loving bond.",
    icon: '<path d="M12 3 L21 10 V21 H3 V10 Z"/><path d="M9.3 14.2 L11.4 16.3 L15 11.8"/>',
  },
  {
    title: "Community Education",
    text: "We advocate for responsible cat ownership, including spaying/neutering, proper care, and understanding feline behavior.",
    icon: '<path d="M12 3.2 A5.3 5.3 0 0 1 14.9 12.9 C14.3 13.5 14 14.3 14 15.2 H10 C10 14.3 9.7 13.5 9.1 12.9 A5.3 5.3 0 0 1 12 3.2 Z"/><path d="M10.1 18 h3.8 M10.9 20.6 h2.2"/>',
  },
  {
    title: "Lifelong Advocacy",
    text: "From kittens to seniors, we stand by every cat's right to a safe, healthy, and happy life—no matter their age or background.",
    icon: '<circle cx="7" cy="9" r="1.6"/><circle cx="12" cy="7.4" r="1.6"/><circle cx="17" cy="9" r="1.6"/><path d="M12 11.6 C14.8 11.6 16.8 13.7 16.8 15.7 C16.8 17.5 15.4 18.6 13.8 18.1 C12.9 17.8 11.1 17.8 10.2 18.1 C8.6 18.6 7.2 17.5 7.2 15.7 C7.2 13.7 9.2 11.6 12 11.6 Z"/>',
  },
];
---

<Base
  title="About us"
  description="TinyPaws is a volunteer-run kitten rescue in Vancouver — no shelter building, just fosters, volunteers, and a lot of very small paws."
>
  <PageHero
    title="About us"
    lead="A volunteer-run kitten rescue in Vancouver — no shelter building, just people who can't walk past a cardboard box that meows."
  />

  <section class="section">
    <div class="container story">
      <div>
        <h2>Our Story</h2>
        <p class="story-p">
          At TinyPaws, we believe every cat deserves a chance at a safe, loving
          life. We are a dedicated non-profit rescue focused on saving
          abandoned, orphaned, and at-risk kittens, providing them with medical
          care, nourishment, and a warm foster home until they're ready for
          adoption.
        </p>
        <p class="story-p">
          Beyond rescue work, TinyPaws is committed to reducing feline
          homelessness through community education, affordable spay/neuter
          initiatives, and adoption events that match our furry friends with
          loving forever homes.
        </p>
        <p class="story-p">
          Each tiny paw makes a big imprint on our hearts—join us in our
          mission to ensure every kitten has the opportunity to purr, play, and
          thrive in a safe and loving environment.
        </p>
      </div>
      <Image
        class="story-photo"
        src={fosterFamily}
        alt="Two kids cuddling a sleeping tabby foster kitten"
        widths={[520]}
        format="webp"
        loading="lazy"
      />
    </div>
  </section>

  <section class="section section--cream">
    <div class="container">
      <h2 class="center">Our Mission</h2>
      <div class="mission-grid">
        {mission.map((m) => (
          <div class="mission">
            <span class="mission-icon" aria-hidden="true">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linejoin="round"
                stroke-linecap="round"
                set:html={m.icon}
              />
            </span>
            <h3>{m.title}</h3>
            <p>{m.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container home-note">
      <div>
        <h2>How the rescue actually runs</h2>
        <p class="story-p">
          TinyPaws started the way most rescues do: one litter too many, and a
          group of neighbours who couldn't say no. What began as a spare
          bathroom and a group chat grew into a foster network across the city
          — every placement, vet run, and adoption day handled by volunteers.
        </p>
        <p class="story-p">
          We still have no building, and we like it that way. Cats don't learn
          to live in homes by living in cages — every TinyPaws kitten grows up
          on someone's sofa, learning stairs, vacuum cleaners, and laps, which
          is exactly the life they're headed to next.
        </p>
      </div>
    </div>
  </section>

  <section class="section section--cream">
    <div class="container contact-wrap">
      <h2>Want to know more?</h2>
      <p class="contact-lead">Say hi — about a cat, a partnership, or a class project.</p>
      <form class="contact-form">
        <label class="sr-only" for="c-email">Email</label>
        <input id="c-email" name="email" type="email" required placeholder="Your email" />
        <label class="sr-only" for="c-msg">Message</label>
        <textarea id="c-msg" name="msg" rows="4" required placeholder="Your message"></textarea>
        <p class="contact-note">Demo form — nothing is sent anywhere.</p>
        <Button type="submit">Contact us</Button>
        <p class="contact-done" role="status" aria-live="polite"></p>
      </form>
    </div>
  </section>
</Base>

<script>
  const form = document.querySelector<HTMLFormElement>(".contact-form")!;
  form.addEventListener("submit", (e) => {
    e.preventDefault();
    if (!form.reportValidity()) return;
    form.reset();
    form.querySelector<HTMLElement>(".contact-done")!.textContent =
      "Message received (demo) — in the live rescue, a volunteer would reply by email.";
  });
</script>

<style>
  .story {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-5);
    align-items: center;
  }
  .story-p {
    margin-top: var(--space-2);
  }
  .story-photo {
    width: 100%;
    height: auto;
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
  }
  .center { text-align: center; }
  .mission-grid {
    margin-top: var(--space-4);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-2);
    text-align: center;
  }
  .mission {
    background: var(--paw-white);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    padding: var(--space-3) 20px;
  }
  .mission-icon {
    display: inline-grid;
    place-items: center;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: var(--paw-orange);
    color: var(--paw-brown);
  }
  .mission-icon svg {
    width: 30px;
    height: 30px;
  }
  .mission h3 {
    margin-top: 14px;
    font-size: 1.15rem;
  }
  .mission p {
    margin-top: 8px;
    font-size: var(--size-small);
  }
  .home-note { max-width: 760px; }
  .contact-wrap { max-width: 640px; }
  .contact-lead { margin-top: 10px; }
  .contact-form {
    margin-top: var(--space-3);
    display: grid;
    gap: var(--space-2);
    justify-items: start;
  }
  .contact-form input,
  .contact-form textarea {
    width: 100%;
    font: 400 1rem/1.4 var(--font-body);
    color: var(--paw-brown);
    background: var(--paw-white);
    border: 2px solid rgba(48, 24, 0, 0.18);
    border-radius: var(--radius-input);
    padding: 14px 16px;
  }
  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: var(--paw-orange);
  }
  .contact-note {
    font-size: var(--size-small);
    color: rgba(48, 24, 0, 0.65);
  }
  .contact-done {
    font-weight: 500;
    color: #2c6b2f;
  }
  @media (max-width: 900px) {
    .story { grid-template-columns: 1fr; }
  }
</style>
