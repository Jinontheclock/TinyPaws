---
import Base from "../layouts/Base.astro";
import Button from "../components/Button.astro";
import { Image } from "astro:assets";
import heroBiscuit from "../assets/cats/biscuit-1.jpg";
import heroMochi from "../assets/cats/mochi-2.jpg";
import featuredMochi from "../assets/cats/mochi-1.jpg";
import persBiscuit from "../assets/cats/biscuit-2.jpg";
import persNori from "../assets/cats/nori-1.jpg";
import persPepper from "../assets/cats/pepper-1.jpg";
import fosterFamily from "../assets/ui/foster-family.jpg";
import { href } from "../lib/url";

/* home structure mirrors the hi-fi: hero → featured cat → three steps →
   personalities band → why we do what we do → you've helped us save */
const steps = [
  {
    title: "Meet your match",
    text: "Browse the cats, take the match quiz, or visit an adoption day. Each one has a story and is looking for the right home.",
  },
  {
    title: "Fill out an application",
    text: "A quick online form about your lifestyle and home, so we can make sure the fit is right — for you and the cat.",
  },
  {
    title: "Welcome home",
    text: "A short trial stay, then the paperwork — and a lifetime of tiny paws on your keyboard.",
  },
];

const personalities = [
  {
    name: "Biscuit",
    slug: "biscuit",
    img: persBiscuit,
    alt: "Biscuit, an orange tabby kitten, peeking over a wooden shelf",
    blurb: "The definition of an easy roommate. Sunbeams, laps, and zero drama.",
  },
  {
    name: "Nori",
    slug: "nori",
    img: persNori,
    alt: "Nori, a tiny grey tabby kitten with a sleepy, unimpressed face",
    blurb: "The tiniest loaf with the biggest opinions. Comes bonded with his brother Miso.",
  },
  {
    name: "Pepper",
    slug: "pepper",
    img: persPepper,
    alt: "Pepper, a tuxedo kitten lying on a bed with both paws up",
    blurb: "Wears a permanent tuxedo and acts accordingly. Elegant, mysterious, a total diva.",
  },
];
---

<Base
  title="Small paws, safe homes"
  description="TinyPaws is a volunteer-run kitten rescue in Vancouver. Meet adoptable kittens, learn the adoption process, foster, volunteer, or donate."
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <h1>Saving kittens, one paw at a&nbsp;time.</h1>
        <p class="hero-lead">
          TinyPaws is a volunteer-run kitten rescue in Vancouver. Small paws,
          safe homes — that's the whole idea.
        </p>
        <div class="hero-actions">
          <Button href={href("/adopt/")}>Meet our kittens</Button>
          <Button href={href("/quiz/")} variant="outline">Take the match quiz</Button>
        </div>
      </div>
      <div class="hero-art">
        <Image
          class="hero-photo hero-photo--tall"
          src={heroBiscuit}
          alt="Biscuit, an orange tabby kitten, sprawled happily on a woven rug"
          widths={[400]}
          format="webp"
          loading="eager"
          fetchpriority="high"
        />
        <Image
          class="hero-photo hero-photo--short"
          src={heroMochi}
          alt="Mochi, a tiny brown tabby kitten wrapped in a cream blanket"
          widths={[400]}
          format="webp"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <section class="section section--cream">
    <div class="container featured">
      <Image
        class="featured-photo"
        src={featuredMochi}
        alt="Mochi, a warm brown tabby kitten, eyes closed and smiling in a sunbeam"
        widths={[400]}
        format="webp"
        loading="lazy"
      />
      <div>
        <h2>Meet our featured cat!</h2>
        <p class="featured-p">
          Mochi is the youngest of the bunch — a four-month-old sweetheart who
          was bottle-fed by her foster and has repaid every feeding with double
          the purrs. She greets you at the door, supervises your cooking, and
          falls asleep mid-pounce. Fully vaccinated, spayed, and ready to find
          her forever home.
        </p>
        <div class="featured-cta">
          <Button href={href("/cats/mochi/")}>Adopt Mochi now</Button>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="center">How adoption works</h2>
      <ol class="steps">
        {steps.map((s, i) => (
          <li class="step">
            <span class="step-no" aria-hidden="true">{i + 1}</span>
            <h3 class="step-title">{s.title}</h3>
            <p>{s.text}</p>
          </li>
        ))}
      </ol>
      <div class="center-cta">
        <Button href={href("/adoption/")}>Start your journey</Button>
      </div>
    </div>
  </section>

  <section class="section section--band">
    <div class="container">
      <h2 class="center band-title">Personalities you'll love</h2>
      <div class="pers-grid">
        {personalities.map((p) => (
          <article class="pers-card">
            <Image
              class="pers-photo"
              src={p.img}
              alt={p.alt}
              widths={[400]}
              format="webp"
              loading="lazy"
            />
            <h3>{p.name}</h3>
            <p>{p.blurb}</p>
            <div class="pers-cta">
              <Button href={href(`/cats/${p.slug}/`)} variant="outline">Meet me</Button>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container why">
      <Image
        class="why-photo"
        src={fosterFamily}
        alt="Two kids cuddling a sleeping tabby foster kitten"
        widths={[520]}
        format="webp"
        loading="lazy"
      />
      <div>
        <h2>Why we do what we do</h2>
        <p class="why-p">
          Every cat deserves to feel safe, loved, and at home. We step in when
          they've been abandoned, forgotten, or born without a place to go —
          medical care first, then a foster sofa, then a family.
        </p>
        <p class="why-p">
          It's not always easy. But every soft purr, headbutt, and happy tail
          makes it worth it.
        </p>
      </div>
    </div>
  </section>

  <section class="section section--cream">
    <div class="container helped">
      <div>
        <h2>You've helped us save…</h2>
        <p class="why-p">
          Behind every number is a little life that got a fresh start — and
          it's all thanks to fosters, adopters, donors, and people who simply
          told a friend about us. We're just getting started.
        </p>
        <div class="hero-actions">
          <Button href={href("/get-involved/#foster")}>Become a foster</Button>
          <Button href={href("/get-involved/#donate")} variant="outline">Donate</Button>
        </div>
      </div>
      <div class="helped-stat" aria-hidden="true">
        <p class="helped-big">500+</p>
        <p>cats rescued, fostered, and matched since day one</p>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    background: var(--paw-cream);
    overflow: hidden;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: var(--space-4);
    padding-block: var(--space-6);
  }
  .hero-lead {
    margin-top: var(--space-3);
    font-size: 1.15rem;
    max-width: 44ch;
  }
  .hero-actions {
    margin-top: var(--space-4);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  /* the hi-fi hero's offset photo pair: two rounded pills, real adoptable cats */
  .hero-art {
    position: relative;
    min-height: 380px;
  }
  .hero-photo {
    position: absolute;
    object-fit: cover;
    border-radius: 999px;
    box-shadow: 0 14px 34px rgba(48, 24, 0, 0.2);
  }
  .hero-photo--tall {
    width: 230px;
    height: 340px;
    right: 130px;
    top: 0;
  }
  .hero-photo--short {
    width: 160px;
    height: 260px;
    right: 0;
    top: 120px;
  }
  .center { text-align: center; }
  .featured {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: var(--space-5);
    align-items: center;
  }
  .featured-photo {
    width: 300px;
    height: 300px;
    object-fit: cover;
    border-radius: 50%;
    box-shadow: var(--shadow-card);
  }
  .featured-p {
    margin-top: var(--space-2);
    max-width: 62ch;
  }
  .featured-cta { margin-top: var(--space-3); }
  .steps {
    list-style: none;
    margin: var(--space-4) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }
  .step {
    background: var(--paw-white);
    border-radius: var(--radius-card);
    padding: var(--space-3);
    box-shadow: var(--shadow-card);
  }
  .step-no {
    display: inline-grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--paw-orange);
    color: var(--paw-brown);
    font: 600 1.3rem/1 var(--font-display);
  }
  .step-title { margin-top: 14px; }
  .step p { margin-top: 8px; }
  .center-cta {
    margin-top: var(--space-4);
    text-align: center;
  }
  /* the hi-fi "Personalities" orange band */
  .section--band {
    background: var(--paw-orange);
  }
  .band-title { color: var(--paw-brown); }
  .pers-grid {
    margin-top: var(--space-4);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }
  .pers-card {
    background: var(--paw-white);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    padding: var(--space-3);
  }
  .pers-photo {
    width: 100%;
    aspect-ratio: 4 / 3;
    height: auto;
    object-fit: cover;
    border-radius: var(--radius-input);
  }
  .pers-card h3 { margin-top: 14px; }
  .pers-card p { margin-top: 6px; }
  .pers-cta { margin-top: var(--space-2); }
  .why,
  .helped {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: var(--space-5);
    align-items: center;
  }
  .helped { grid-template-columns: 1.1fr 0.9fr; }
  .why-photo {
    width: 100%;
    height: auto;
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
  }
  .why-p { margin-top: var(--space-2); }
  .helped-stat {
    background: var(--paw-white);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    padding: var(--space-4);
    text-align: center;
  }
  .helped-big {
    font: 600 3.6rem/1 var(--font-display);
    color: var(--paw-orange-ink);
  }
  .helped-stat p:last-child {
    margin: 8px auto 0;
    max-width: 24ch;
  }
  @media (max-width: 900px) {
    .hero-grid,
    .featured,
    .pers-grid,
    .steps,
    .why,
    .helped {
      grid-template-columns: 1fr;
    }
    .hero-art { min-height: 260px; }
    .featured-photo {
      width: 240px;
      height: 240px;
      margin-inline: auto;
    }
    .why-photo { order: 2; }
  }
</style>
