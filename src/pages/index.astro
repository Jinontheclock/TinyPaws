---
import Base from "../layouts/Base.astro";
import Button from "../components/Button.astro";
import { Image } from "astro:assets";
import colGotcha from "../assets/ui/people-exp-1.jpg";
import colPurple from "../assets/ui/people-community.jpg";
import colCradle from "../assets/ui/people-onboarding.jpg";
import colFluffy from "../assets/ui/people-adopt-1.jpg";
import colPair from "../assets/ui/people-adopt-2.jpg";
import featuredMochi from "../assets/cats/mochi-1.jpg";
import persBiscuit from "../assets/cats/biscuit-2.jpg";
import persNori from "../assets/cats/nori-1.jpg";
import persPepper from "../assets/cats/pepper-1.jpg";
import fosterFamily from "../assets/ui/foster-family.jpg";
import familyCouple from "../assets/ui/family-couple.jpg";
import { href } from "../lib/url";

/* home structure mirrors the hi-fi: hero → featured cat → three steps
   (icons joined by a dashed path) → personalities band → why we do /
   you've helped (one section, alternating rows) */
const steps = [
  {
    title: "Meet your match",
    text: "Browse the cats, take the match quiz, or visit an adoption day. Each one has a story and is looking for the right home.",
    icon: '<path fill="currentColor" stroke="none" d="M20.5 21.5 L18.5 8.5 L29 16 A15 15 0 0 1 35 16 L45.5 8.5 L43.5 21.5 A14.5 14.5 0 0 1 46.5 30 C46.5 33.6 44.9 36.8 42.4 39 C48.5 41.6 52 46.2 52 50.5 C52 55 47 57.5 32 57.5 C17 57.5 12 55 12 50.5 C12 46.2 15.5 41.6 21.6 39 C19.1 36.8 17.5 33.6 17.5 30 A14.5 14.5 0 0 1 20.5 21.5 Z"/><path fill="none" d="M52 50 C58 49 60.5 44.5 59.5 39.5" stroke-width="3.4"/>',
  },
  {
    title: "Fill out an application",
    text: "A quick online form about your lifestyle and home, so we can make sure the fit is right — for you and the cat.",
    icon: '<rect x="14" y="10" width="32" height="44" rx="4" stroke-width="3.4"/><path d="M25 10 h14 v6 a2 2 0 0 1 -2 2 h-10 a2 2 0 0 1 -2 -2 Z" fill="currentColor" stroke="none"/><path d="M21 26 h18 M21 33 h18 M21 40 h10" stroke-width="3.4"/><path d="M42 36 L52 46 L54.5 54 L46.5 51.5 L36.5 41.5 Z" fill="var(--paw-white)" stroke-width="3"/>',
  },
  {
    title: "Welcome home",
    text: "A short trial stay, then the paperwork — and a lifetime of tiny paws on your keyboard.",
    icon: '<path d="M32 53 C20 44 12 36.5 12 27.5 A11.5 11.5 0 0 1 32 20 A11.5 11.5 0 0 1 52 27.5 C52 34 48 39.8 41 45.5 C38.5 47.5 36.5 50.5 38.5 53.5 C40 55.7 43 56 45 54.5" stroke-width="3.4"/>',
  },
];

const personalities = [
  {
    name: "Biscuit",
    slug: "biscuit",
    img: persBiscuit,
    alt: "Biscuit, an orange tabby kitten, peeking over a wooden shelf",
    blurb: "The definition of an easy roommate. Sunbeams, laps, and zero drama.",
  },
  {
    name: "Nori",
    slug: "nori",
    img: persNori,
    alt: "Nori, a tiny grey tabby kitten with a sleepy, unimpressed face",
    blurb: "The tiniest loaf with the biggest opinions. Comes bonded with his sister Miso.",
  },
  {
    name: "Pepper",
    slug: "pepper",
    img: persPepper,
    alt: "Pepper, a tuxedo kitten lying on a bed with both paws up",
    blurb: "Wears a permanent tuxedo and acts accordingly. Elegant, mysterious, a total diva.",
  },
];
---

<Base
  title="Small paws, safe homes"
  description="TinyPaws is a volunteer-run kitten rescue in Vancouver. Meet adoptable kittens, learn the adoption process, foster, volunteer, or donate."
>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <h1>Saving kittens, one paw at a&nbsp;time.</h1>
        <p class="hero-lead">
          TinyPaws is a volunteer-run kitten rescue in Vancouver. Small paws,
          safe homes — that's the whole idea.
        </p>
        <div class="hero-actions">
          <Button href={href("/adopt/")}>Meet our kittens</Button>
          <Button href={href("/quiz/")} variant="outline">Take the match quiz</Button>
        </div>
      </div>
      <div class="collage" aria-label="Photos of TinyPaws adopters with their cats">
        <figure class="col-piece col-polaroid col-miso">
          <Image
            src={colGotcha}
            alt="A beaming adopter holding her two newly adopted kittens"
            widths={[420]}
            format="webp"
            loading="eager"
            fetchpriority="high"
          />
          <figcaption>Gotcha day!</figcaption>
        </figure>
        <figure class="col-piece col-pill col-clover">
          <Image
            src={colPurple}
            alt="An adopter in a purple shirt holding her brown tabby cat"
            widths={[420]}
            format="webp"
            loading="eager"
          />
        </figure>
        <figure class="col-piece col-circle col-waffles">
          <Image
            src={colCradle}
            alt="An adopter gently cradling a tiny tabby kitten"
            widths={[300]}
            format="webp"
            loading="eager"
          />
        </figure>
        <figure class="col-piece col-polaroid col-hazel">
          <Image
            src={colFluffy}
            alt="An adopter hugging her fluffy cream longhaired cat"
            widths={[360]}
            format="webp"
            loading="eager"
          />
          <figcaption>Forever home</figcaption>
        </figure>
        <figure class="col-piece col-circle col-pebble">
          <Image
            src={colPair}
            alt="An adopter smiling with a pair of tabby kittens in her arms"
            widths={[260]}
            format="webp"
            loading="eager"
          />
        </figure>
        <span class="col-sticker col-paw" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <circle cx="7" cy="9" r="1.9" />
            <circle cx="12" cy="7.2" r="1.9" />
            <circle cx="17" cy="9" r="1.9" />
            <path d="M12 11.4 C15 11.4 17.2 13.7 17.2 15.8 C17.2 17.8 15.6 19 13.9 18.5 C12.9 18.2 11.1 18.2 10.1 18.5 C8.4 19 6.8 17.8 6.8 15.8 C6.8 13.7 9 11.4 12 11.4 Z" />
          </svg>
        </span>
        <span class="col-sticker col-heart" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 20 C7.5 16.2 4.5 13.3 4.5 10.3 A3.9 3.9 0 0 1 12 8.6 A3.9 3.9 0 0 1 19.5 10.3 C19.5 13.3 16.5 16.2 12 20 Z" />
          </svg>
        </span>
      </div>
    </div>
  </section>

  <section class="section section--deep">
    <div class="container featured">
      <Image
        class="featured-photo"
        src={featuredMochi}
        alt="Mochi, a warm brown tabby kitten, eyes closed and smiling in a sunbeam"
        widths={[400]}
        format="webp"
        loading="lazy"
      />
      <div>
        <h2>Meet our featured cat!</h2>
        <p class="featured-p">
          Mochi is the youngest of the bunch — a four-month-old sweetheart who
          was bottle-fed by her foster and has repaid every feeding with double
          the purrs. She greets you at the door, supervises your cooking, and
          falls asleep mid-pounce. Fully vaccinated, spayed, and ready to find
          her forever home.
        </p>
        <div class="featured-cta">
          <Button href={href("/cats/mochi/")}>Adopt Mochi now</Button>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="center">How adoption works</h2>
      <ol class="path-steps">
        {steps.map((s, i) => (
          <li class="pstep" data-reveal style={`transition-delay:${i * 0.12}s`}>
            <span class="pstep-icon" aria-hidden="true">
              <svg
                viewBox="0 0 64 64"
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={s.icon}
              />
            </span>
            <h3 class="pstep-title">{s.title}</h3>
            <p>{s.text}</p>
          </li>
        ))}
      </ol>
      <div class="center-cta">
        <Button href={href("/adoption/")} variant="dark">Start your journey</Button>
      </div>
    </div>
  </section>

  <section class="section section--band">
    <div class="container">
      <h2 class="center band-title">Personalities you'll love</h2>
      <div class="pers-grid">
        {personalities.map((p) => (
          <article class="pers-card">
            <div class="pers-photo-wrap">
              <Image
                class="pers-photo"
                src={p.img}
                alt={p.alt}
                widths={[400]}
                format="webp"
                loading="lazy"
              />
            </div>
            <h3>{p.name}</h3>
            <p>{p.blurb}</p>
            <div class="pers-cta">
              <Button href={href(`/cats/${p.slug}/`)} variant="outline">Meet me</Button>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="wh-row" data-reveal>
        <Image
          class="wh-photo"
          src={fosterFamily}
          alt="Two kids cuddling a sleeping tabby foster kitten"
          widths={[520]}
          format="webp"
          loading="lazy"
        />
        <div>
          <h2>Why we do what we do</h2>
          <p class="why-p">
            Every cat deserves to feel safe, loved, and at home. We step in
            when they've been abandoned, forgotten, or born without a place to
            go — medical care first, then a foster sofa, then a family.
          </p>
          <p class="why-p">
            It's not always easy. But every soft purr, headbutt, and happy
            tail makes it worth it.
          </p>
        </div>
      </div>

      <div class="wh-row wh-row--flip" data-reveal>
        <div>
          <h2>You've helped us save…</h2>
          <p class="why-p">
            Since day one, we've rescued over 500 cats, matched hundreds with
            amazing families, and supported a growing team of foster homes.
            Behind every number is a little life that got a fresh start — and
            it's all thanks to fosters, adopters, donors, and people who
            simply told a friend about us. We're just getting started.
          </p>
          <div class="hero-actions">
            <Button href={href("/get-involved/#foster")}>Become a foster</Button>
            <Button href={href("/get-involved/#donate")} variant="outline">Donate</Button>
          </div>
        </div>
        <Image
          class="wh-photo"
          src={familyCouple}
          alt="A smiling couple holding their two fluffy adopted ragdoll cats"
          widths={[640]}
          format="webp"
          loading="lazy"
        />
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    background: var(--paw-cream);
    overflow: hidden;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    align-items: center;
    gap: var(--space-4);
    padding-block: var(--space-6);
  }
  .hero-lead {
    margin-top: var(--space-3);
    font-size: 1.15rem;
    max-width: 44ch;
  }
  .hero-actions {
    margin-top: var(--space-4);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  /* scrapbook collage hero: overlapping rotated pieces in mixed shapes —
     polaroid frames, a pill, ringed circles — plus sticker accents */
  .collage {
    position: relative;
    min-height: 480px;
  }
  .col-piece {
    position: absolute;
    margin: 0;
    transform: rotate(var(--rot, 0deg));
    animation: col-float 5s ease-in-out infinite alternate;
    transition: transform 0.25s var(--ease);
  }
  .col-piece:hover {
    animation-play-state: paused;
    transform: rotate(var(--rot, 0deg)) scale(1.05);
    z-index: 9;
  }
  @keyframes col-float {
    from { transform: rotate(var(--rot, 0deg)) translateY(0); }
    to { transform: rotate(var(--rot, 0deg)) translateY(-9px); }
  }
  .col-piece img {
    display: block;
    object-fit: cover;
  }
  .col-polaroid {
    background: var(--paw-white);
    padding: 10px 10px 8px;
    border-radius: 16px;
    box-shadow: 0 16px 34px rgba(48, 24, 0, 0.22);
  }
  .col-polaroid img { border-radius: 8px; }
  .col-polaroid figcaption {
    font: 500 1rem/1 var(--font-display);
    color: var(--paw-brown);
    text-align: center;
    padding-block: 8px 4px;
  }
  .col-miso {
    --rot: -4deg;
    left: 24%;
    top: 0;
    z-index: 3;
    animation-delay: -1s;
  }
  .col-miso img { width: 218px; height: 300px; object-position: 42% 22%; }
  .col-clover {
    --rot: 3deg;
    right: 0;
    top: 46px;
    z-index: 2;
    animation-delay: -2.4s;
  }
  .col-clover img {
    width: 196px;
    height: 282px;
    border-radius: 999px;
    box-shadow: 0 14px 30px rgba(48, 24, 0, 0.2);
    object-position: 55% 25%;
  }
  .col-waffles {
    --rot: 0deg;
    left: 7%;
    bottom: 26px;
    z-index: 4;
    animation-delay: -3.6s;
  }
  .col-waffles img {
    width: 150px;
    height: 150px;
    object-position: 52% 28%;
    border-radius: 50%;
    border: 6px solid var(--paw-orange);
    box-shadow: 0 12px 26px rgba(48, 24, 0, 0.2);
  }
  .col-hazel {
    --rot: 5deg;
    right: 10px;
    bottom: 0;
    z-index: 4;
    animation-delay: -0.6s;
  }
  .col-hazel img { width: 176px; height: 168px; object-position: 50% 22%; }
  .col-pebble {
    --rot: -7deg;
    left: 0;
    top: 34px;
    z-index: 1;
    animation-delay: -2s;
  }
  .col-pebble img {
    width: 118px;
    height: 118px;
    object-position: 50% 30%;
    border-radius: 50%;
    border: 5px solid var(--paw-white);
    box-shadow: 0 10px 22px rgba(48, 24, 0, 0.18);
  }
  .col-sticker {
    position: absolute;
    display: inline-grid;
    place-items: center;
    z-index: 5;
    filter: drop-shadow(0 4px 8px rgba(48, 24, 0, 0.2));
  }
  .col-paw {
    color: var(--paw-orange);
    right: 176px;
    top: 0;
    transform: rotate(16deg);
  }
  .col-paw svg { width: 58px; height: 58px; }
  .col-heart {
    color: var(--paw-orange-ink);
    left: 30%;
    bottom: 0;
    transform: rotate(-12deg);
  }
  .col-heart svg { width: 42px; height: 42px; }
  @media (prefers-reduced-motion: reduce) {
    .col-piece { animation: none; }
  }
  .center { text-align: center; }
  .featured {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: var(--space-5);
    align-items: center;
  }
  .featured-photo {
    width: 300px;
    height: 300px;
    object-fit: cover;
    border-radius: 50%;
    box-shadow: var(--shadow-card);
  }
  .featured-p {
    margin-top: var(--space-2);
    max-width: 62ch;
  }
  .featured-cta { margin-top: var(--space-3); }
  /* the hi-fi three-step path: icons joined by a dashed line */
  .path-steps {
    list-style: none;
    margin: var(--space-5) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }
  .pstep {
    position: relative;
    text-align: center;
    padding-inline: var(--space-2);
  }
  .pstep:not(:last-child)::after {
    content: "";
    position: absolute;
    top: 36px;
    left: calc(50% + 62px);
    width: calc(100% - 124px);
    border-top: 3px dashed rgba(48, 24, 0, 0.3);
  }
  .pstep-icon {
    display: inline-grid;
    place-items: center;
    color: var(--paw-brown);
    transition: transform 0.3s var(--ease);
  }
  .pstep-icon svg {
    width: 72px;
    height: 72px;
  }
  .pstep:hover .pstep-icon {
    transform: translateY(-6px) rotate(-3deg);
  }
  .pstep-title {
    margin-top: var(--space-3);
    font-size: 1.25rem;
    color: var(--paw-orange-ink);
  }
  .pstep p {
    margin: 10px auto 0;
    max-width: 34ch;
    font-size: var(--size-small);
  }
  .center-cta {
    margin-top: var(--space-4);
    text-align: center;
  }
  /* the hi-fi "Personalities" orange band */
  .section--band {
    background: var(--paw-orange);
  }
  .band-title { color: var(--paw-brown); }
  .pers-grid {
    margin-top: var(--space-4);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }
  .pers-card {
    display: flex;
    flex-direction: column;
    background: var(--paw-white);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    padding: var(--space-3);
    transition: transform 0.25s var(--ease), box-shadow 0.25s var(--ease);
  }
  .pers-card:hover {
    transform: translateY(-6px) rotate(-0.6deg);
    box-shadow: 0 16px 36px rgba(48, 24, 0, 0.22);
  }
  .pers-photo-wrap {
    overflow: hidden;
    border-radius: var(--radius-input);
  }
  .pers-photo {
    width: 100%;
    aspect-ratio: 4 / 3;
    height: auto;
    object-fit: cover;
    transition: transform 0.35s var(--ease);
  }
  .pers-card:hover .pers-photo {
    transform: scale(1.05);
  }
  .pers-card h3 { margin-top: 14px; }
  .pers-card p { margin-top: 6px; }
  .pers-cta { margin-top: auto; padding-top: var(--space-2); }
  /* why-we-do + you've-helped: one section, alternating photo/text rows */
  .wh-row {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: var(--space-5);
    align-items: center;
  }
  .wh-row--flip {
    grid-template-columns: 1.1fr 0.9fr;
    margin-top: var(--space-6);
  }
  .wh-photo {
    width: 100%;
    height: auto;
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
  }
  .why-p { margin-top: var(--space-2); }
  @media (max-width: 900px) {
    .hero-grid,
    .featured,
    .pers-grid,
    .path-steps,
    .wh-row,
    .wh-row--flip {
      grid-template-columns: 1fr;
    }
    .pstep:not(:last-child)::after { display: none; }
    /* compact collage: same pieces, tighter frame */
    .collage {
      min-height: 350px;
      max-width: 420px;
      margin-inline: auto;
      width: 100%;
    }
    .col-miso img { width: 158px; height: 216px; }
    .col-clover img { width: 138px; height: 200px; }
    .col-waffles img { width: 110px; height: 110px; }
    .col-hazel img { width: 128px; height: 122px; }
    .col-hazel { right: 12px; }
    .col-pebble img { width: 86px; height: 86px; }
    .col-paw { right: 116px; }
    .col-paw svg { width: 44px; height: 44px; }
    .col-heart svg { width: 34px; height: 34px; }
    .featured-photo {
      width: 240px;
      height: 240px;
      margin-inline: auto;
    }
    .wh-photo { order: 2; }
  }
</style>
