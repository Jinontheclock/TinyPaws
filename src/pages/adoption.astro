---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import Button from "../components/Button.astro";
import { Image } from "astro:assets";
import bannerAdoption from "../assets/ui/banner-adoption.jpg";
import stepBrowse from "../assets/cats/biscuit-1.jpg";
import stepApply from "../assets/cats/mochi-2.jpg";
import stepChat from "../assets/cats/nori-2.jpg";
import stepTrial from "../assets/cats/pepper-1.jpg";
import stepHome from "../assets/cats/pickles-1.jpg";

/* the hi-fi "How to Adopt" path: circular cat photos in orange rings,
   zigzagging down the page with a dashed spine between them */
const steps = [
  {
    title: "Browse & meet",
    text: "Look through the adoptable cats, take the match quiz, or meet kittens at an adoption day. Bonded pairs go home together.",
    img: stepBrowse,
    alt: "Biscuit, an orange tabby kitten, sprawled happily on a woven rug",
  },
  {
    title: "Submit an application",
    text: "Fill in the application below. It isn't first-come-first-served — we match on fit, not speed.",
    img: stepApply,
    alt: "Mochi, a tiny brown tabby kitten wrapped in a cream blanket",
  },
  {
    title: "Chat with a volunteer",
    text: "A foster volunteer calls you within a few days to talk lifestyle, home setup, and any other pets.",
    img: stepChat,
    alt: "Nori, a grey tabby kitten, looking up with big round eyes",
  },
  {
    title: "Trial stay",
    text: "A one-week trial at your home with supplies provided, so everyone can be sure — including the cat.",
    img: stepTrial,
    alt: "Pepper, a tuxedo kitten lying on a bed with both paws up",
  },
  {
    title: "Bring them home",
    text: "Sign the adoption agreement and pay the fee ($240, covering vaccines, spay/neuter, and microchip).",
    img: stepHome,
    alt: "Pickles, a long-haired tabby kitten mid-stretch on a blanket",
  },
];
---

<Base
  title="Adoption process"
  description="How adopting a TinyPaws kitten works, from application to trial stay — plus the adoption application form."
>
  <PageHero
    image={bannerAdoption}
    imageAlt="An orange-and-white cat mid-groom, tongue out over a paw"
    title="How adoption works"
    lead="Five steps, no surprises. The fee ($240) covers vaccines, spay or neuter, and a microchip."
  />

  <section class="section">
    <div class="container process">
      <h2 class="sr-only">The five steps</h2>
      <ol class="zigzag">
        {steps.map((s, i) => (
          <li class={`zstep${i % 2 ? " zstep--flip" : ""}`} data-reveal>
            <span class="zstep-photo">
              <Image src={s.img} alt={s.alt} widths={[440]} format="webp" loading="lazy" />
            </span>
            <div class="zstep-copy">
              <h3>
                <span class="zstep-no">Step {i + 1}:</span> {s.title}
              </h3>
              <p>{s.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="ready-band">
    <div class="container ready-inner">
      <h2>Ready to adopt?</h2>
      <Button href="#apply">Apply now</Button>
    </div>
  </section>

  <section class="section section--cream" id="apply">
    <div class="container form-wrap">
      <h2>Adoption application</h2>
      <p class="form-note">
        Demo form — validation runs in your browser and nothing is sent
        anywhere.
      </p>

      <form class="apply-form" novalidate>
        <div class="field">
          <label for="f-name">Full name</label>
          <input id="f-name" name="name" type="text" autocomplete="name" required />
          <p class="error" id="f-name-error"></p>
        </div>
        <div class="field">
          <label for="f-email">Email</label>
          <input id="f-email" name="email" type="email" autocomplete="email" required />
          <p class="error" id="f-email-error"></p>
        </div>
        <div class="field">
          <label for="f-cat">Which cat are you applying for?</label>
          <select id="f-cat" name="cat" required>
            <option value="">Choose a cat…</option>
            <option>Mochi</option>
            <option>Biscuit</option>
            <option>Pepper</option>
            <option>Nori (bonded with Miso)</option>
            <option>Clementine</option>
            <option>Tofu</option>
            <option>Pickles</option>
            <option>Bean</option>
            <option>Mittens</option>
            <option>Opal</option>
            <option>Jasper</option>
            <option>Not sure yet — help me choose</option>
          </select>
          <p class="error" id="f-cat-error"></p>
        </div>
        <div class="field">
          <label for="f-home">Tell us about your home</label>
          <textarea
            id="f-home"
            name="home"
            rows="4"
            required
            placeholder="Apartment or house? Other pets? Kids? Anything you'd want a foster to know."></textarea>
          <p class="error" id="f-home-error"></p>
        </div>
        <button class="submit" type="submit">Send application</button>
        <p class="success" role="status" aria-live="polite"></p>
      </form>
    </div>
  </section>
</Base>

<style>
  /* zigzag path: photo rings alternate sides, a dashed spine links them */
  .zigzag {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: 880px;
    display: grid;
    gap: var(--space-5);
  }
  .zstep {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: var(--space-4);
    align-items: center;
    position: relative;
  }
  .zstep--flip {
    grid-template-columns: 1fr 260px;
  }
  .zstep--flip .zstep-photo { order: 2; }
  .zstep--flip .zstep-copy {
    order: 1;
    text-align: right;
    justify-items: end;
  }
  .zstep--flip .zstep-copy p { margin-left: auto; }
  .zstep:not(:last-child)::after {
    content: "";
    position: absolute;
    left: 50%;
    bottom: calc(-1 * var(--space-5));
    height: var(--space-5);
    border-left: 3px dashed rgba(48, 24, 0, 0.3);
  }
  .zstep-photo {
    display: block;
    width: 230px;
    height: 230px;
    border-radius: 50%;
    overflow: hidden;
    border: 8px solid var(--paw-orange);
    box-shadow: var(--shadow-card);
    justify-self: center;
    transition: transform 0.3s var(--ease);
  }
  .zstep:hover .zstep-photo {
    transform: scale(1.04) rotate(-2deg);
  }
  .zstep-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .zstep-no {
    color: var(--paw-orange-ink);
  }
  .zstep-copy h3 { font-size: 1.4rem; }
  .zstep-copy p {
    margin-top: 10px;
    max-width: 44ch;
  }
  /* the hi-fi "Ready to Adopt?" brown band */
  .ready-band {
    background: var(--paw-brown);
    padding-block: var(--space-5);
  }
  .ready-inner {
    display: grid;
    justify-items: center;
    gap: var(--space-3);
    text-align: center;
  }
  .ready-band h2 { color: var(--paw-cream); }
  @media (max-width: 720px) {
    .zstep,
    .zstep--flip {
      grid-template-columns: 1fr;
      justify-items: center;
    }
    .zstep--flip .zstep-photo { order: 0; }
    .zstep--flip .zstep-copy {
      order: 1;
      text-align: center;
      justify-items: center;
    }
    .zstep-copy { text-align: center; }
    .zstep-copy p { margin-inline: auto; }
    .zstep:not(:last-child)::after { display: none; }
  }
  .form-wrap {
    max-width: 720px;
  }
  .form-note {
    margin-top: 10px;
    font-size: var(--size-small);
    color: rgba(48, 24, 0, 0.65);
  }
  .apply-form {
    margin-top: var(--space-4);
    display: grid;
    gap: var(--space-3);
  }
  .field {
    display: grid;
    gap: 8px;
  }
  label {
    font: 500 1.05rem/1.3 var(--font-display);
  }
  input,
  select,
  textarea {
    font: 400 1rem/1.4 var(--font-body);
    color: var(--paw-brown);
    background: var(--paw-white);
    border: 2px solid rgba(48, 24, 0, 0.18);
    border-radius: var(--radius-input);
    padding: 14px 16px;
  }
  input:focus,
  select:focus,
  textarea:focus {
    outline: none;
    border-color: var(--paw-orange);
  }
  .field.is-invalid input,
  .field.is-invalid select,
  .field.is-invalid textarea {
    border-color: #b3261e;
  }
  .error {
    min-height: 1.2em;
    font-size: var(--size-small);
    color: #b3261e;
  }
  .submit {
    justify-self: start;
    font: 500 var(--size-button) / 1 var(--font-display);
    background: var(--paw-orange);
    color: var(--paw-brown);
    border: 0;
    border-radius: var(--radius-pill);
    padding: 16px 34px;
    cursor: pointer;
    transition: background 0.15s var(--ease), transform 0.15s var(--ease);
  }
  .submit:hover {
    background: #e97e14;
    transform: translateY(-2px);
  }
  .success {
    font-weight: 500;
    color: #2c6b2f;
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>(".apply-form")!;
  const success = form.querySelector<HTMLElement>(".success")!;

  // arriving from a cat profile (?cat=Name) preselects that cat
  const wanted = new URLSearchParams(location.search).get("cat");
  if (wanted) {
    const sel = form.querySelector<HTMLSelectElement>("#f-cat")!;
    const match = [...sel.options].find((o) => o.text.startsWith(wanted));
    if (match) sel.value = match.value;
  }

  const validators: Record<string, (v: string) => string> = {
    name: (v) => (v.trim().length >= 2 ? "" : "Please enter your name."),
    email: (v) => (/^\S+@\S+\.\S+$/.test(v) ? "" : "Please enter a valid email address."),
    cat: (v) => (v ? "" : "Please choose a cat (or “not sure yet”)."),
    home: (v) => (v.trim().length >= 20 ? "" : "A couple of sentences helps us match you well (20+ characters)."),
  };

  const check = (el: HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement) => {
    const msg = validators[el.name]?.(el.value) ?? "";
    const field = el.closest(".field")!;
    const error = field.querySelector<HTMLElement>(".error")!;
    field.classList.toggle("is-invalid", !!msg);
    error.textContent = msg;
    el.setAttribute("aria-invalid", msg ? "true" : "false");
    return !msg;
  };

  form.addEventListener("submit", (e) => {
    e.preventDefault();
    const fields = [...form.querySelectorAll<HTMLInputElement>("input, select, textarea")];
    const results = fields.map(check);
    const firstBad = fields[results.indexOf(false)];
    if (firstBad) {
      firstBad.focus();
      success.textContent = "";
      return;
    }
    form.reset();
    success.textContent =
      "Application received (demo) — in the live rescue, a volunteer would reply within 3 days. Thank you!";
  });
  form.addEventListener("blur", (e) => {
    const t = e.target as HTMLElement;
    if (t.matches("input, select, textarea")) check(t as HTMLInputElement);
  }, true);
</script>
