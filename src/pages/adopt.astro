---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import bannerAdopt from "../assets/ui/banner-adopt.jpg";
import CatCard from "../components/CatCard.astro";
import Button from "../components/Button.astro";
import { href } from "../lib/url";

const cats = await getCollection("cats");
const byWait = [...cats].sort((a, b) => b.data.daysInFoster - a.data.daysInFoster);
---

<Base
  title="Cats available for adoption"
  description="Meet the kittens currently looking for homes at TinyPaws — filter by age, energy, and adoption status."
>
  <PageHero
    image={bannerAdopt}
    imageAlt="A lynx-point kitten with blue eyes rolling on a white blanket"
    title="Cats available for adoption"
    lead="Everyone here grew up in a foster home, so we can tell you exactly who you're meeting."
  />

  <section class="learn-strip">
    <div class="container learn-row">
      <p class="learn-label">Learn more about:</p>
      <div class="learn-pills">
        <Button href={href("/adoption/")} variant="outline">How to adopt</Button>
        <Button href={href("/adoption/#apply")}>Apply to adopt</Button>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="sr-only">Browse and filter the cats</h2>
      <form class="filters" aria-label="Filter cats">
        <div class="filter-group" role="radiogroup" aria-label="Age">
          <label class="fpill"><input type="radio" name="age" value="all" checked /><span>All ages</span></label>
          <label class="fpill"><input type="radio" name="age" value="kitten" /><span>Under 6 months</span></label>
          <label class="fpill"><input type="radio" name="age" value="junior" /><span>6 months +</span></label>
        </div>
        <span class="filter-sep" aria-hidden="true"></span>
        <label class="fpill"><input type="checkbox" name="available" /><span>Available only</span></label>
        <p class="filter-count" role="status" aria-live="polite"></p>
      </form>

      <div class="cat-grid" id="cat-grid">
        {byWait.map((c) => {
          const months = parseInt(c.data.age);
          return (
            <div
              class="cat-cell"
              data-age={months < 6 ? "kitten" : "junior"}
              data-status={c.data.status}
            >
              <CatCard
                slug={c.id}
                name={c.data.name}
                age={c.data.age}
                sex={c.data.sex}
                breed={c.data.breed}
                status={c.data.status}
                coat={c.data.coat}
                accent={c.data.accent}
                temperament={c.data.temperament}
                photos={c.data.photos}
                photoAlt={c.data.photoAlt}
              />
            </div>
          );
        })}
      </div>
    </div>
  </section>
</Base>

<style>
  /* one calm filter bar: age segments, a divider, an "available" toggle,
     and the live count riding on the right */
  .filters {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    background: var(--paw-cream);
    border-radius: var(--radius-pill);
    padding: 8px;
  }
  .filter-group {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .fpill {
    position: relative;
    cursor: pointer;
  }
  .fpill input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .fpill span {
    display: inline-block;
    font: 500 var(--size-small)/1 var(--font-body);
    color: var(--paw-brown);
    border-radius: var(--radius-pill);
    padding: 11px 18px;
    transition: background 0.15s var(--ease), color 0.15s var(--ease);
  }
  .fpill:hover span {
    background: var(--paw-cream-deep);
  }
  .fpill:has(input:checked) span {
    background: var(--paw-brown);
    color: var(--paw-cream);
  }
  .fpill:has(input:focus-visible) span {
    outline: 3px solid var(--paw-orange);
    outline-offset: 1px;
  }
  .filter-sep {
    width: 1px;
    align-self: stretch;
    margin-block: 6px;
    background: rgba(48, 24, 0, 0.15);
  }
  .filter-count {
    margin-left: auto;
    padding-right: 14px;
    font-size: var(--size-small);
    color: rgba(48, 24, 0, 0.65);
  }
  @media (max-width: 700px) {
    .filters {
      border-radius: var(--radius-card);
    }
    .filter-count {
      width: 100%;
      padding: 4px 14px 6px;
    }
  }
  .cat-grid {
    margin-top: var(--space-3);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
  }
  .cat-cell[hidden] {
    display: none;
  }
  @media (max-width: 900px) {
    .cat-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 600px) {
    .cat-grid {
      grid-template-columns: 1fr;
    }
  }
  .learn-strip {
    background: var(--paw-cream-deep);
    padding-block: var(--space-3);
  }
  .learn-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .learn-label {
    font: 500 1.1rem/1 var(--font-display);
  }
  .learn-pills {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    justify-content: center;
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>(".filters")!;
  const cells = [...document.querySelectorAll<HTMLElement>(".cat-cell")];
  const count = document.querySelector<HTMLElement>(".filter-count")!;
  const apply = () => {
    const data = new FormData(form);
    const age = data.get("age");
    const status = data.get("available") ? "available" : "all";
    let shown = 0;
    for (const cell of cells) {
      const ok =
        (age === "all" || cell.dataset.age === age) &&
        (status === "all" || cell.dataset.status === status);
      cell.hidden = !ok;
      if (ok) shown++;
    }
    count.textContent = `${shown} of ${cells.length} cats shown`;
  };
  form.addEventListener("change", apply);
  apply();
</script>
