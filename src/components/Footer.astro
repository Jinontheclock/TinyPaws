---
import PawLogo from "./PawLogo.astro";
import { href } from "../lib/url";
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <PawLogo size={36} />
      <p class="footer-tag">Small paws, safe homes.</p>
      <p class="footer-note">
        A volunteer-run kitten rescue in Vancouver, BC. Every adoption starts
        with a safe foster home.
      </p>
    </div>
    <nav aria-label="Footer">
      <h4>Explore</h4>
      <ul>
        <li><a href={href("/adopt/")}>Cats for adoption</a></li>
        <li><a href={href("/quiz/")}>Match quiz</a></li>
        <li><a href={href("/adoption/")}>Adoption process</a></li>
        <li><a href={href("/events/")}>Events</a></li>
      </ul>
    </nav>
    <nav aria-label="Support">
      <h4>Support</h4>
      <ul>
        <li><a href={href("/get-involved/#foster")}>Foster</a></li>
        <li><a href={href("/get-involved/#volunteer")}>Volunteer</a></li>
        <li><a href={href("/get-involved/#donate")}>Donate</a></li>
      </ul>
    </nav>
  </div>
  <div class="container footer-legal">
    <p>© 2026 TinyPaws Kitten Rescue · A student-built demo site — not a live organization.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--paw-brown);
    color: var(--paw-cream);
    padding-block: var(--space-5) var(--space-3);
    margin-top: var(--space-6);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: var(--space-4);
  }
  .footer-tag {
    font: 500 1.2rem/1.3 var(--font-display);
    color: var(--paw-cream);
    margin-top: 10px;
  }
  .footer-note {
    font-size: var(--size-small);
    opacity: 0.75;
    margin-top: 8px;
    max-width: 34ch;
  }
  .site-footer h4 {
    color: var(--paw-cream);
    font-size: 1.05rem;
    margin-bottom: 12px;
  }
  .site-footer ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 8px;
  }
  .site-footer a {
    color: var(--paw-cream);
    text-decoration: none;
    opacity: 0.85;
  }
  .site-footer a:hover {
    opacity: 1;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .footer-legal {
    margin-top: var(--space-4);
    padding-top: var(--space-2);
    border-top: 1px solid rgba(245, 236, 216, 0.18);
  }
  .footer-legal p {
    font-size: var(--size-small);
    opacity: 0.65;
  }
  @media (max-width: 700px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }
  }
</style>
