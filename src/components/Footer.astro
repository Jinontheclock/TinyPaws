---
import PawLogo from "./PawLogo.astro";
import { href } from "../lib/url";
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <PawLogo size={36} />
      <p class="footer-tag">Small paws, safe homes.</p>
      <p class="footer-note">
        A volunteer-run kitten rescue in Vancouver, BC. Every adoption starts
        with a safe foster home.
      </p>
    </div>
    <nav aria-label="Info">
      <h2 class="footer-head">Info</h2>
      <ul>
        <li><a href={href("/about/")}>About us</a></li>
        <li><a href={href("/resources/")}>Resources</a></li>
        <li><a href={href("/events/")}>Events</a></li>
        <li><a href={href("/quiz/")}>Match quiz</a></li>
      </ul>
    </nav>
    <nav aria-label="Action">
      <h2 class="footer-head">Action</h2>
      <ul>
        <li><a href={href("/adopt/")}>Adopt</a></li>
        <li><a href={href("/get-involved/")}>Get involved</a></li>
        <li><a href={href("/get-involved/#donate")}>Donate</a></li>
        <li><a href={href("/shop/")}>Gift shop</a></li>
      </ul>
    </nav>
    <div class="footer-sub">
      <h2 class="footer-head">Subscribe</h2>
      <form class="sub-form">
        <label class="sr-only" for="sub-email">Email</label>
        <input id="sub-email" name="email" type="email" required placeholder="Email" />
        <button type="submit">Subscribe</button>
      </form>
      <p class="sub-done" role="status" aria-live="polite"></p>
      <p class="sub-note">Demo — nothing is sent anywhere.</p>
    </div>
  </div>
  <div class="container footer-legal">
    <p>info@tinypaws.ca · (604) 123-4567 — demo contact details</p>
    <p>© 2026 TinyPaws Kitten Rescue · A student-built demo site — not a live organization.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--paw-brown);
    color: var(--paw-cream);
    padding-block: var(--space-5) var(--space-3);
    margin-top: var(--space-6);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 0.8fr 0.8fr 1.2fr;
    gap: var(--space-4);
  }
  .footer-tag {
    font: 500 1.2rem/1.3 var(--font-display);
    color: var(--paw-cream);
    margin-top: 10px;
  }
  .footer-note {
    font-size: var(--size-small);
    opacity: 0.75;
    margin-top: 8px;
    max-width: 34ch;
  }
  .footer-head {
    color: var(--paw-cream);
    font-size: 1.05rem;
    margin-bottom: 12px;
  }
  .site-footer ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 8px;
  }
  .site-footer a {
    color: var(--paw-cream);
    text-decoration: none;
    opacity: 0.85;
  }
  .site-footer a:hover {
    opacity: 1;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .footer-legal {
    margin-top: var(--space-4);
    padding-top: var(--space-2);
    border-top: 1px solid rgba(245, 236, 216, 0.18);
  }
  .footer-legal p {
    font-size: var(--size-small);
    opacity: 0.65;
  }
  @media (max-width: 700px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }
  }
  .sub-form {
    display: flex;
    gap: 8px;
  }
  .sub-form input {
    flex: 1;
    min-width: 0;
    font: 400 0.95rem/1.4 var(--font-body);
    color: var(--paw-brown);
    background: var(--paw-cream);
    border: 0;
    border-radius: var(--radius-pill);
    padding: 10px 16px;
  }
  .sub-form button {
    font: 500 0.95rem/1 var(--font-display);
    background: var(--paw-orange);
    color: var(--paw-brown);
    border: 0;
    border-radius: var(--radius-pill);
    padding: 10px 18px;
    cursor: pointer;
  }
  .sub-form button:hover { background: #e97e14; }
  .sub-done {
    margin-top: 8px;
    font-size: var(--size-small);
    color: var(--paw-cream);
  }
  .sub-note {
    margin-top: 6px;
    font-size: var(--size-small);
    opacity: 0.55;
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>(".sub-form")!;
  form.addEventListener("submit", (e) => {
    e.preventDefault();
    if (!form.reportValidity()) return;
    form.reset();
    form.parentElement!.querySelector<HTMLElement>(".sub-done")!.textContent =
      "Subscribed (demo) — thanks!";
  });
</script>
