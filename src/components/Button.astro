---
/* pill button from the style tile: orange fill (dark-brown text = AA),
   brown outline, or solid dark-brown (the hi-fi "Start Your Journey").
   With href it's a link; with type it's a real <button> (form submits). */
interface Props {
  href?: string;
  type?: "submit" | "button";
  variant?: "primary" | "outline" | "dark";
}
const { href, type, variant = "primary" } = Astro.props;
---

{
  href ? (
    <a class={`btn btn--${variant}`} href={href}><slot /></a>
  ) : (
    <button class={`btn btn--${variant}`} type={type ?? "button"}><slot /></button>
  )
}

<style>
  .btn {
    display: inline-block;
    font: 500 var(--size-button) / 1 var(--font-display);
    padding: 16px 34px;
    border: 0;
    border-radius: var(--radius-pill);
    background: none;
    cursor: pointer;
    text-decoration: none;
    transition: transform 0.15s var(--ease), background 0.15s var(--ease),
      color 0.15s var(--ease);
  }
  .btn:hover {
    transform: translateY(-2px);
  }
  .btn--primary {
    background: var(--paw-orange);
    color: var(--paw-brown);
  }
  .btn--primary:hover {
    background: #e97e14;
  }
  .btn--outline {
    border: 2px solid var(--paw-brown);
    color: var(--paw-brown);
  }
  .btn--outline:hover {
    background: var(--paw-brown);
    color: var(--paw-cream);
  }
  .btn--dark {
    background: var(--paw-brown);
    color: var(--paw-cream);
  }
  .btn--dark:hover {
    background: #4a2a08;
  }
</style>
