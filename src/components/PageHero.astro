---
/* page-title band. Cream strip by default; pass `image` for the hi-fi-style
   photo banner — title in cream over a warm brown wash for AA contrast. */
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  lead?: string;
  image?: ImageMetadata;
  imageAlt?: string;
  /* object-position for the banner crop, e.g. "70% 40%" keeps a face
     visible when narrow screens crop the sides */
  imagePosition?: string;
}
const { title, lead, image, imageAlt = "", imagePosition = "50% 50%" } = Astro.props;
---

{
  image ? (
    <div class="page-hero page-hero--photo">
      <Image
        class="hero-img"
        src={image}
        alt={imageAlt}
        widths={[800, 1440]}
        sizes="100vw"
        format="webp"
        loading="eager"
        fetchpriority="high"
        style={`object-position: ${imagePosition}`}
      />
      <div class="hero-veil" aria-hidden="true"></div>
      <div class="container hero-inner">
        <h1>{title}</h1>
        {lead && <p class="lead">{lead}</p>}
      </div>
    </div>
  ) : (
    <div class="page-hero">
      <div class="container">
        <h1>{title}</h1>
        {lead && <p class="lead">{lead}</p>}
      </div>
    </div>
  )
}

<style>
  .page-hero {
    background: var(--paw-cream);
    padding-block: var(--space-5);
    text-align: center;
  }
  .lead {
    margin: 14px auto 0;
    font-size: 1.1rem;
    max-width: 56ch;
  }
  .page-hero--photo {
    position: relative;
    padding-block: var(--space-6);
    overflow: hidden;
    display: grid;
    align-items: center;
  }
  .page-hero--photo .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero-veil {
    position: absolute;
    inset: 0;
    background: rgba(48, 24, 0, 0.48);
  }
  .page-hero--photo .hero-inner {
    position: relative;
  }
  .page-hero--photo h1,
  .page-hero--photo .lead {
    color: var(--paw-cream);
  }
</style>
