---
/* cream page-title band, like the hi-fi screens' top strip */
interface Props {
  title: string;
  lead?: string;
}
const { title, lead } = Astro.props;
---

<div class="page-hero">
  <div class="container">
    <h1>{title}</h1>
    {lead && <p class="lead">{lead}</p>}
  </div>
</div>

<style>
  .page-hero {
    background: var(--paw-cream);
    padding-block: var(--space-5);
    text-align: center;
  }
  .lead {
    margin: 14px auto 0;
    font-size: 1.1rem;
    max-width: 56ch;
  }
</style>
