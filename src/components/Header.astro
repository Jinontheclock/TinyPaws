---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import wordmark from "../assets/ui/wordmark.webp";
import { href } from "../lib/url";

/* nav mirrors the hi-fi design: Adopt · Resources · Get Involved · Events ·
   Gift Shop · About us, plus the search toggle and the Donate Now pill */
const links = [
  { label: "Adopt", path: "/adopt/" },
  { label: "Resources", path: "/resources/" },
  { label: "Get Involved", path: "/get-involved/" },
  { label: "Events", path: "/events/" },
  { label: "Gift Shop", path: "/shop/" },
  { label: "About us", path: "/about/" },
];
const current = Astro.url.pathname;

/* the search index is baked in at build time — cats, pages, guides, shop */
const cats = await getCollection("cats");
const index = [
  ...cats.map((c) => ({
    title: c.data.name,
    kind: "Cat",
    text: `${c.data.sex} ${c.data.age} ${c.data.breed} ${c.data.temperament.join(" ")}`,
    url: href(`/cats/${c.id}/`),
  })),
  { title: "Cats available for adoption", kind: "Page", text: "browse gallery adopt filter kittens", url: href("/adopt/") },
  { title: "Match quiz", kind: "Page", text: "quiz match find your cat five questions", url: href("/quiz/") },
  { title: "How adoption works", kind: "Page", text: "adoption process steps fee application form apply", url: href("/adoption/") },
  { title: "Adoption application", kind: "Page", text: "apply form application", url: href("/adoption/#apply") },
  { title: "Get involved", kind: "Page", text: "foster volunteer donate help wishlist", url: href("/get-involved/") },
  { title: "Donate", kind: "Page", text: "donation give support vet bills", url: href("/get-involved/#donate") },
  { title: "Events", kind: "Page", text: "adoption day fundraiser orientation calendar market", url: href("/events/") },
  { title: "Resources", kind: "Page", text: "guides help questions contact", url: href("/resources/") },
  { title: "Caring for a cat", kind: "Guide", text: "nutrition feeding health wellness behaviour bonded pairs kittens seniors", url: href("/resources/caring-for-a-cat/") },
  { title: "Gift shop", kind: "Page", text: "merch tee shirt mug tote stickers beanie print shop cart", url: href("/shop/") },
  { title: "About us", kind: "Page", text: "story mission contact rescue vancouver", url: href("/about/") },
];
---

<header class="site-header">
  <div class="container header-row">
    <a class="brand" href={href("/")} aria-label="TinyPaws home">
      <Image class="brand-mark" src={wordmark} alt="" widths={[200]} format="webp" loading="eager" />
      <span class="sr-only">TinyPaws</span>
    </a>

    <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="site-nav" aria-label="Menu">
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>

    <nav id="site-nav" class="site-nav" aria-label="Main">
      <ul>
        {links.map((l) => (
          <li>
            <a href={href(l.path)} aria-current={current === href(l.path) ? "page" : undefined}>{l.label}</a>
          </li>
        ))}
        <li class="nav-search">
          <button type="button" class="search-toggle" aria-expanded="false" aria-controls="search-panel" aria-label="Search the site">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <circle cx="10.5" cy="10.5" r="6.5" stroke="currentColor" stroke-width="2.4" />
              <path d="M15.5 15.5 L21 21" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" />
            </svg>
          </button>
        </li>
        <li class="nav-cta">
          <a class="donate" href={href("/get-involved/#donate")}>Donate Now</a>
        </li>
      </ul>
    </nav>
  </div>

  <div class="search-panel" id="search-panel" data-index={JSON.stringify(index)} hidden>
    <div class="container">
      <form class="search-form" role="search">
        <label class="sr-only" for="site-q">Search the site</label>
        <input id="site-q" type="search" placeholder="Search cats, guides, pages…" autocomplete="off" />
        <button type="button" class="search-close" aria-label="Close search">×</button>
      </form>
      <p class="search-count" role="status" aria-live="polite"></p>
      <ul class="search-results"></ul>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--paw-white);
    border-bottom: 1px solid rgba(48, 24, 0, 0.08);
  }
  .header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding-block: 12px;
  }
  .brand { display: inline-flex; align-items: center; }
  .brand-mark {
    display: block;
    height: 42px;
    width: auto;
  }
  .site-nav ul {
    display: flex;
    align-items: center;
    gap: clamp(14px, 2.2vw, 30px);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .site-nav a {
    font: 500 1rem/1 var(--font-body);
    color: var(--paw-brown);
    text-decoration: none;
    padding: 8px 2px;
  }
  .site-nav a:hover,
  .site-nav a[aria-current="page"] {
    color: var(--paw-orange-ink);
  }
  .site-nav a[aria-current="page"] {
    text-decoration: underline;
    text-underline-offset: 6px;
    text-decoration-thickness: 2px;
  }
  .search-toggle {
    all: unset;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    padding: 8px;
    color: var(--paw-brown);
    border-radius: 50%;
  }
  .search-toggle:hover,
  .search-toggle[aria-expanded="true"] {
    color: var(--paw-orange-ink);
  }
  .search-toggle:focus-visible {
    outline: 3px solid var(--paw-orange);
  }
  .nav-cta .donate {
    display: inline-block;
    background: var(--paw-orange);
    color: var(--paw-brown);
    font: 500 1rem/1 var(--font-display);
    padding: 12px 22px;
    border-radius: var(--radius-pill);
    transition: transform 0.15s var(--ease), background 0.15s var(--ease);
  }
  .nav-cta .donate:hover {
    transform: translateY(-1px);
    background: #e97e14;
  }
  /* ── inline search panel, dropping from the header ── */
  .search-panel {
    border-top: 1px solid rgba(48, 24, 0, 0.08);
    background: var(--paw-white);
    padding-block: var(--space-2) var(--space-3);
    box-shadow: 0 18px 30px rgba(48, 24, 0, 0.12);
  }
  .search-form {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  #site-q {
    flex: 1;
    min-width: 0;
    font: 400 1.05rem/1.4 var(--font-body);
    color: var(--paw-brown);
    background: var(--paw-cream);
    border: 2px solid transparent;
    border-radius: var(--radius-input);
    padding: 13px 16px;
  }
  #site-q:focus {
    outline: none;
    border-color: var(--paw-orange);
    background: var(--paw-white);
  }
  .search-close {
    all: unset;
    cursor: pointer;
    width: 38px;
    height: 38px;
    display: inline-grid;
    place-items: center;
    border-radius: 50%;
    font-size: 1.4rem;
    color: var(--paw-brown);
  }
  .search-close:hover { background: var(--paw-cream); }
  .search-close:focus-visible { outline: 3px solid var(--paw-orange); }
  .search-count {
    margin-top: 8px;
    font-size: var(--size-small);
    color: rgba(48, 24, 0, 0.7);
  }
  .search-results {
    list-style: none;
    margin: 8px 0 0;
    padding: 0;
    display: grid;
    gap: 8px;
    max-height: 320px;
    overflow-y: auto;
  }
  .search-results :global(a) {
    display: flex;
    align-items: center;
    gap: 12px;
    background: var(--paw-cream);
    border-radius: var(--radius-input);
    padding: 11px 16px;
    text-decoration: none;
    color: inherit;
  }
  .search-results :global(a:hover) {
    background: var(--paw-cream-deep);
  }
  .search-results :global(.result-kind) {
    flex: none;
    font: 500 0.72rem/1 var(--font-body);
    background: var(--paw-white);
    border-radius: var(--radius-pill);
    padding: 5px 10px;
  }
  .search-results :global(.result-title) {
    font: 500 1rem/1.3 var(--font-display);
  }
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: 0;
    padding: 10px;
    cursor: pointer;
  }
  .nav-toggle-bar {
    width: 24px;
    height: 3px;
    border-radius: 2px;
    background: var(--paw-brown);
    transition: transform 0.2s var(--ease), opacity 0.2s var(--ease);
  }

  @media (max-width: 840px) {
    .nav-toggle {
      display: flex;
    }
    .site-nav {
      display: none;
      position: absolute;
      inset: 100% 0 auto 0;
      background: var(--paw-white);
      border-bottom: 1px solid rgba(48, 24, 0, 0.08);
      box-shadow: var(--shadow-card);
    }
    .site-nav.is-open {
      display: block;
    }
    .site-nav ul {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 8px 24px 20px;
    }
    .site-nav li {
      border-bottom: 1px solid rgba(48, 24, 0, 0.06);
    }
    .site-nav li:last-child {
      border-bottom: 0;
    }
    .site-nav a {
      display: block;
      padding: 14px 2px;
      font-size: 1.05rem;
    }
    .search-toggle {
      padding: 14px 2px;
      border-radius: 0;
    }
    .nav-cta {
      padding-top: 12px;
    }
    .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(1) {
      transform: translateY(8px) rotate(45deg);
    }
    .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(2) {
      opacity: 0;
    }
    .nav-toggle[aria-expanded="true"] .nav-toggle-bar:nth-child(3) {
      transform: translateY(-8px) rotate(-45deg);
    }
  }
</style>

<script>
  const toggle = document.querySelector(".nav-toggle");
  const nav = document.getElementById("site-nav");
  toggle?.addEventListener("click", () => {
    const open = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!open));
    nav?.classList.toggle("is-open", !open);
  });

  /* ── inline search ── */
  const panel = document.getElementById("search-panel") as HTMLElement;
  const sToggle = document.querySelector<HTMLButtonElement>(".search-toggle")!;
  const input = panel.querySelector<HTMLInputElement>("#site-q")!;
  const results = panel.querySelector<HTMLElement>(".search-results")!;
  const count = panel.querySelector<HTMLElement>(".search-count")!;
  const index: { title: string; kind: string; text: string; url: string }[] =
    JSON.parse(panel.dataset.index!);

  const run = () => {
    const q = input.value.trim().toLowerCase();
    results.innerHTML = "";
    if (q.length < 2) {
      count.textContent = "";
      return;
    }
    const hits = index.filter(
      (e) => e.title.toLowerCase().includes(q) || e.text.toLowerCase().includes(q),
    );
    count.textContent = hits.length
      ? `${hits.length} result${hits.length > 1 ? "s" : ""}`
      : "No results — try a shorter word.";
    for (const h of hits.slice(0, 8)) {
      const li = document.createElement("li");
      const a = document.createElement("a");
      a.href = h.url;
      const kind = document.createElement("span");
      kind.className = "result-kind";
      kind.textContent = h.kind;
      const title = document.createElement("span");
      title.className = "result-title";
      title.textContent = h.title;
      a.append(kind, title);
      li.append(a);
      results.append(li);
    }
  };

  const openSearch = (open: boolean) => {
    panel.hidden = !open;
    sToggle.setAttribute("aria-expanded", String(open));
    if (open) input.focus();
    else {
      input.value = "";
      run();
    }
  };
  sToggle.addEventListener("click", () => openSearch(panel.hidden));
  panel.querySelector(".search-close")!.addEventListener("click", () => openSearch(false));
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !panel.hidden) openSearch(false);
  });

  input.addEventListener("input", run);
  panel.querySelector(".search-form")!.addEventListener("submit", (e) => e.preventDefault());
</script>
